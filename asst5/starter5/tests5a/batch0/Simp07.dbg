901##...sltu $at,$t1,$t2
905##...beq $at,$zero,3188
908#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

912:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

912#    jal readLogicalChar # read next character
916#    subu $t1,$v0,'0' # convert digit to 0-9 value
920#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
921##...sltu $at,$t1,$t2
925##...beq $at,$zero,944

928#    mul $t3,$t3,$t2 # multiply old value by 10
929##...mult $t3,$t2
933##...mflo $t3
936#    addu $t3,$t3,$t1 # add in value of new digit
940#    j digitLoop

944:  doneDigitLoop:

    # "push back" unused character into queue
944#    sw $v0,lastCharRead

    # restore return address
948#    lw $ra,($sp)
952#    addu $sp, 4
