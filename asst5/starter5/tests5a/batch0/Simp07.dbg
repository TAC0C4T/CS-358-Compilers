0:main:
0#  jal vm_init
4#  li $s6, 1
8#  li $s7, 0
12#  jal newObject
16#  la $t0, CLASS_Main
20#  sw $t0, -12($s7)
24#  addu $sp,$sp,4
28#  move $s2, $s7
32#  jal mth_main_Main
36#  li $v0, 10
40#  syscall
44:mth_main_Main:
44#  li $t0, 27
48#  subu $sp, $sp, 8
52#  sw $s5, 4($sp)
56#  sw $t0, 0($sp)
60#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
64:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
64#    lw $t0,-8($s2) # get word with hash bits from this
68#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
72#    addu $t0,$t1

76#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
80:mth_equals_Object:
80#    move $t0,$s2 # first pointer (this)
84#    lw $t1,($sp) # second pointer
88#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
89##...subu $at,$t0,$t1
93##...sltiu $t0,$at,1

96#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
100:mth_hashCode_String:
100#    move $t0,$s2 # put this pointer in t0

104#    li $t2,0 # current hash value
108#    lw $t1,-4($t0) # negative of number of characters in string
112#    beq $t1,$zero,done_hashCode_String # if zero length => done
116#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
120#    and $t0,0xfffffffc # adjust for padding
121##...lui $at,65535
125##...ori $at,$at,0xfffc
129##...and $t0,$t0,$at
132#    subu $t1,$t0,$t1 # address at end of string +12
136:loop_hashCode_String:    
136#    sll $t4,$t2,5 # multiply by 32
140#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
144#    lbu $t3,-12($t0) # current character
148#    addu $t2,$t3 # add in current character
152#    addu $t0,1 # go to next character's address
156#    bne $t0,$t1,loop_hashCode_String # loop back if more
160:done_hashCode_String:    

    # push int on stack
160#    move $t0, $t2 # put $t2 in return slot
164#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
168:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
168#    subu $sp,4
172#    sw $ra,($sp)
    
    # get hash value
176#    lw $t2,-12($s2) # vtable address
180#    lw $t0,($t2) # method address
184#    jalr $t0
188#    subu $sp,8 # push result (int in $t0) on stack
192#    sw $s5,4($sp)
196#    sw $t0,($sp)

    # compute print-size of hash value
200#    li $t0, 1
204#    lw $t1, ($sp)
208#    srl $t1,$t1,4
212#    beq $t1,$zero,toString_skip_loop
216:toString_loop_top:
216#    addu $t0,1
220#    srl $t1,$t1,4
224#    bne $t1,$zero,toString_loop_top
228:toString_skip_loop:
228#    subu $sp,8
232#    sw $s5,4($sp)
236#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
240#    lw $t2,-12($s2) # vtable address
244#    move $t0,$t2
248:toString_checkTagBit:
248#    subu $t0,1
252#    lb $t1,($t0)
256#    and $t1,0x80
257##...lui $at,0
261##...ori $at,$at,0x80
265##...and $t1,$t1,$at
268#    beq $t1,$zero,toString_checkTagBit
272#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
276#    subu $sp,8
280#    sw $t1,($sp)
284#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
288#    move $s7,$zero # -4 offset header word
292#    lw $t4,8($sp) # bytes for hash value
296#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
300#    addu $t4,8
304#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
308#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

312#    li $t0,CLASS_String # store string vtable address into ...
316#    sw $t0,-12($s7) # ... -12 offset in object header
320#    lw $t2,-12($s2) # our object's vtable address
324#    lw $t5,4($sp) # number characters in prefix
328#    lw $t1,12($sp) # number of characters in hashcode
332#    addu $t3,$t1,$t5 # number of characters in string ...
336#    addu $t3,1 # ... including the '@' character
340#    subu $t0,$zero,$t3 # store negated length into ...
344#    sw $t0,-4($s7) # ... -4 offset header word
348#    lw $t0,-8($s7) # get -8 offset header-word
352#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
353##...slt $at,$t0,$zero
357##...beq $at,$zero,376
360#    and $t0,0xff # mask off object's hash value ...
361##...lui $at,0
365##...ori $at,$at,0xff
369##...and $t0,$t0,$at
372#    sw $t0,-8($s7) # ... and store back into -8 header-word
376:skipMask_toString:
376#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
380#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
384#    subu $t4,$t2,$t5
388:toString_copyLoop:    
388#    lb $t3,($t4)
392#    and $t3,0x7f # mask off sign bit (in case first word)
393##...lui $at,0
397##...ori $at,$at,0x7f
401##...and $t3,$t3,$at
404#    sb $t3,-8($t0)
408#    addu $t4,1
412#    addu $t0,1
416#    blt $t4,$t2,toString_copyLoop
417##...slt $at,$t4,$t2
421##...bne $at,$zero,388

    # copy the '@' sign
424#    li $t3,'@'
428#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
432#    addu $t2,$t0,$t1 # address of last byte in string to store +8
436#    lw $t3,20($sp) # hash code to print
440:toString_hashCopyLoop:
440#    and $t4,$t3,0xf
444#    srl $t3,4
448#    lb $t4,hexChars($t4)
452#    sb $t4,-8($t2)
456#    subu $t2,$t2,1
460#    bgt $t2,$t0,toString_hashCopyLoop
461##...slt $at,$t0,$t2
465##...bne $at,$zero,440

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
468#    addu $sp,28
472#    lw $ra,($sp)
476#    addu $sp,4
480#    move $t0, $s7 # return string we created
484#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
488:mth_equals_String:
    
    # quick test for obvious false
488#    lw $t0,($sp) # second parameter
492#    beq $t0,$zero,goEsFalse # go return false if null
496#    lw $t1,-12($t0) # vtable pointer
500#    la $t2,CLASS_String # string vtable pointer
504#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
508#    subu $sp,12
512#    sw $ra,8($sp)
516#    sw $s2,4($sp)
520#    sw $t0,($sp)
524#    jal mth_compareTo_String
528#    lw $s2, 4($sp) #restore this pointer and pop parameters
532#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
536#    seq $t0,$t0,$zero
537##...subu $at,$t0,$zero
541##...sltiu $t0,$at,1

    # pop return address and return $t0
544#    lw $ra,($sp)
548#    addu $sp,4

552#    jr $ra # return
    
556:goEsFalse:
    # put 0 in $t0 and return
556#    li $t0, 0
560#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
564:mth_toString_String:
    #we are a string, so return this.
564#    move $t0, $s2
568#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
572:mth_readLine_Lib:
    
572#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
576#    sw $ra, 4($sp) # save $ra
580#    move $t1,$sp # save "original" sp

584:  doRead:

    # read the character
584#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
588#    subu $t2,$v0,13
592#    bne $t2,$zero,notReturnRL
596#    jal readLogicalChar
600#    subu $t2,$v0,10 # check for newline
604#    beq $t2,$zero,foundNewLine
608#    sw $v0,lastCharRead # push back character into queue
612#    j foundNewLine # go process the line

616:  notReturnRL:

    # at this point, $v0 has our character

616#    subu $t0,$v0,10
620#    beq $t0,$zero,foundNewLine
624#    blt $v0,$zero,foundEof
625##...slt $at,$v0,$zero
629##...bne $at,$zero,644

    # we have a character, so push it onto stack
632#    subu $sp,$sp,4
636#    sw $v0,($sp)

    # loop back up to get next character
640#    j doRead

644:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
644#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
648#    li $s7, 0 # return-value: null
652#    j rlReturn # return

656:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
656#    subu $t0,$t1,$sp # number of chars we read (times 4)
660#    srl $s6,$t0,2 # number of words on stack with chars
664#    subu $sp,$sp,4 # push char-count ...
668#    sw $s6,($sp) # ... onto stack
672#    addu $t2,$t0,5 # GC tag, incl. for count-word
676#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
680#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
684#    srl $s6,$s6,2  # data words in object
