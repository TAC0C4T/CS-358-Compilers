    # lower limit, and if we're < the higher limit
3048#    lw $t2,-12($t2) # vtable address
3052#    sge $t0,$t2,$t0 # are we >= the lower limit?
3053##...slt $t0,$t2,$t0
3057##...xori $t0,$t0,0x1
3060#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3064#    and $t2,$t0,$t1
3068#    sw $t2,($sp)
3072:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3072#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3076:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3076#    li $v0,4 # syscall-code for print-string
3080#    syscall
3084:exit:
    # print termination message
3084#    li $v0,4 # syscall-code for print-string
3088#    la $a0,exitString
3092#    syscall

    # print number of garbage collections
3096#    li $v0,4 # syscall-code for print-string
3100#    la $a0,gcCountMsg
3104#    syscall # print "Number of ..."
3108#    lw $a0,gcCount # number of GC's
3112#    li $v0,1 # code for print-int
3116#    syscall
3120#    li $v0,4 # syscall-code for print-string
3124#    la $a0,newlineString
3128#    syscall # print newline

    # terminate execution
3132#    li $v0,10 #syscall-code for "exit"
3136#    syscall

3140:outOfHeapMemory:
3140#    la $a0,heapMemoryMsg
3144#    j exitError
3148:divByZeroError:
3148#    la $a0,divByZeroMsg
3152#    j exitError
3156:strIndexOutOfBounds:
3156#    la $a0,strIndexOutOfBoundsMsg
3160#    j exitError
3164:arrayIndexOutOfBounds:
3164#    la $a0,arrayIndexOutOfBoundsMsg
3168#    j exitError
3172:arraySizeOutOfBounds:
3172#    la $a0,arraySizeOutOfBoundsMsg
3176#    j exitError
3180:nullPtrException:
3180#    la $a0,nullPtrExceptionMsg
3184#    j exitError
3188:badIntegerFormat:
3188#    la $a0,badIntegerFormatMsg
3192#    j exitError
3196:castException:
3196#    la $a0,castExceptionMsg
3200#    j exitError
############## data section ################
    .data
3384:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3400:cur_seg:
    .word 0

3404:lastCharRead:
    .word -2 # -2 => no buffered character
3408:prevHashConstant:
    .word 0x2785173c
3412:gcCount:
    .word 0

3416:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3443:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3466:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3501:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3535:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3568:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3599:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3647:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3668:gcMsg: 
      .asciiz "\nGC!\n"
3674:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3706:nullStr:
    .asciiz "null"
3711:trueString:
    .asciiz "true"
3716:falseString:
    .asciiz "false"
3722:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
3750:newlineString:
    .asciiz "\n"
    
    .align 2
3752:stack_bottom:
    .word 0
