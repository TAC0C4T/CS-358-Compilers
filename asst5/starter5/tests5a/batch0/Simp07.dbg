###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
808:mth_readInt_Lib:

    # save $ra by pushing onto stack
808#    subu $sp,$sp,4
812#    sw $ra,($sp)

816:  riSkipWhiteLoop:
    # read a character
816#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
820#    subu $t0,$v0,32
824#    bgt $t0,$zero,nonWhite
825##...slt $at,$zero,$t0
829##...bne $at,$zero,872
832#    beq $t0,$zero,riSkipWhiteLoop # start over if space
836#    subu $t0,$v0,10
840#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
844#    subu $t0,$v0,9
848#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
852#    subu $t0,$v0,13
856#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
860#    subu $t0,$v0,12
864#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
868#    j badIntegerFormat # illegal integer char: abort program

872:  nonWhite:
872#    subu $t0,$v0,'-'
876#    li $t4,1 # final multiplier
880#    bne $t0,$zero,helpReadInt # go read
884#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
888#    jal readLogicalChar

892:  helpReadInt:
