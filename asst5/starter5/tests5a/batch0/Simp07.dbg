    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3016#    lw $t2,-12($t2) # vtable address
3020#    bge $t2,$t1,castException
3021##...slt $at,$t2,$t1
3025##...beq $at,$zero,3196
3028#    blt $t2,$t0,castException
3029##...slt $at,$t2,$t0
3033##...bne $at,$zero,3196
    
    # return, leaving object unchanged on stack
