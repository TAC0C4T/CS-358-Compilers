########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
2916:vm_init:

    # mark bottom of stack
2916#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
2920#    move $s2,$zero

    #set up the "five" register
2924#    li $s5,5

2928#    la $s3,seg0_start
2932#    la $s4,seg0_end
2933##...lui $s4,16
2937##...addiu $s4,$s4,3756
    
    # return
2940#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
2944:divide:
    # get parameters; abort if divisor zero
2944#    lw $t0,($sp)
2948#    lw $t1,8($sp)
2952#    beq $t0,$zero,divByZeroError
    
    # perform division
2956#    div $t1,$t0
2960#    mflo $t0

    # store result, adjust stack and return
2964#    addu $sp,$sp,8 # adjust stack
2968#    sw $t0,($sp) # store result
2972#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
2976:remainder:
    # get parameters; abort if divisor zero
2976#    lw $t0,($sp)
2980#    lw $t1,8($sp)
2984#    beq $t0,$zero,divByZeroError
    
    # perform division
2988#    div $t1,$t0
2992#    mfhi $t0

    # store result, adjust stack and return
2996#    addu $sp,$sp,8 # adjust stack
3000#    sw $t0,($sp) # store result
3004#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3008:checkCast:
    # get object, allow immediately if null
3008#    lw $t2,($sp)
3012#    beq $t2,$zero,checkCastReturn
