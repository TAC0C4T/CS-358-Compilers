# str.charAt(n) - library method (class String)
# accesses a character in a string, as in Java
# - parameters:
#   - ($sp) - the index, n
#   - 4($sp) - GC tag
#   - 8($sp) - old this pointer
#   - $s2    - this pointer
# - returns:
#   - $t0 - the character found.
########################################################
1612:mth_charAt_String:
    # get string
1612#    move $t0,$s2

    # check that index is in bounds
1616#    lw $t1,-4($t0) # negative of # data words in string
1620#    subu $t3,$zero,$t1 # # chars in string
1624#    lw $t2,($sp) # index
1628#    bgeu $t2,$t3,strIndexOutOfBounds
1629##...sltu $at,$t2,$t3
1633##...beq $at,$zero,3156

    # access element
1636#    lw $t1,-8($t0) # # data words in object
1640#    sll $t1,$t1,2 # - byte-offset from end of chars
1644#    subu $t1,$t2,$t1 # - address of first char in string, offset by 8
1648#    addu $t0,$t0,$t1 # - address of our char, offset by 8
1652#    lb $t0,-8($t0) # our char

    # return
1656#    jr $ra

########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
1660:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
1660#    subu $sp,$sp,8
1664#    sw $ra,4($sp)

    # save current sp
1668#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
1672#    li $t3,10

    # get argument, negate if negative
1676#    lw $t1,8($sp)
1680#    bge $t1,$zero,itsNonNegLoop
1681##...slt $at,$t1,$zero
1685##...beq $at,$zero,1692
1688#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
1692:  itsNonNegLoop:
1692#    divu $t1,$t3
1696#    mflo $t1 # quotient
1700#    mfhi $t4 # remainder
1704#    addu $t4,$t4,'0' # turn remainder into digit
1708#    subu $sp,$sp,4
1712#    sw $t4,($sp) # push digit onto stack
1716#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
1720#    lw $t4,8($t0)
1724#    bge $t4,$zero,itsSkipNeg
1725##...slt $at,$t4,$zero
1729##...beq $at,$zero,1744
1732#    li $t4,'-'
1736#    subu $sp,$sp,4
1740#    sw $t4,($sp)
1744:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
1744#    subu $s6,$t0,$sp
1748#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
1752#    sw $t3,($t0)
1756#    srl $s6,$s6,2
1760#    subu $sp,$sp,4
1764#    sw $s6,($sp)
    
    # allocate memory
1768#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
1772#    srl $s6,$s6,2
1776#    move $s7,$zero # no "object" words in object
1780#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
1784#    lw $t0,4($sp)
1788#    addu $sp,$sp,8

    # store "String" tag into class field
1792#    subu $s7,$s7,8 # address of header-1 word
1796#    la $t1,CLASS_String
1800#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
1804#    lw $t4,($s7) # # data words in source string
1808#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
1809##...slt $at,$t4,$zero
1813##...beq $at,$zero,1832
1816#    and $t4,0xff # mask off object's hash value ...
1817##...lui $at,0
1821##...ori $at,$at,0xff
1825##...and $t4,$t4,$at
1828#    sw $t4,($s7) # ... and store back into -8 header-word
1832:skipMask_intToString:
    
    # store negative of char-count into header-2 word
1832#    subu $t0,$zero,$t0
1836#    sw $t0,4($s7)

1840#    lw $t1,($s7) # number of data words in string
1844#    sll $t1,$t1,2 # number data bytes in string
1848#    subu $t1,$s7,$t1 # first location to store chars in string
1852#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
1856:  itsLoop:
1856#    lw $t2,($sp)
1860#    addu $sp,$sp,4
1864#    sb $t2,($t1)
1868#    addu $t1,$t1,1
1872#    bne $t1,$t0,itsLoop

    ####################################################
    # At this point
    # - ($t0+15)&0xfffffffe is our return value
    # - ($sp) contains garbage (old GC tag)
    # - 4($sp) contains return address
    ####################################################

    # adjust stack, restore return address; return
1876#    lw $ra,4($sp)
1880#    addu $sp,$sp,8
1884#    addu $t0,$t0,15
1888#    and $t0,$t0,0xfffffffc
1889##...lui $at,65535
1893##...ori $at,$at,0xfffc
1897##...and $t0,$t0,$at
1900#    jr $ra

########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
1904:mth_intToChar_Lib:
    # save return address
1904#    subu $sp,$sp,4
1908#    sw $ra,($sp)

    # allocate object
1912#    li $s6,2
1916#    move $s7,$zero
1920#    jal newObject

    # get n from string.
1924#    lw $t1,8($sp)

    # store "String" tag into class field
1928#    la $t0,CLASS_String
1932#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
1936#    lw $t4,-8($s7) # # data words in source string
1940#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
1941##...slt $at,$t4,$zero
1945##...beq $at,$zero,1964
1948#    and $t4,0xff # mask off object's hash value ...
1949##...lui $at,0
1953##...ori $at,$at,0xff
1957##...and $t4,$t4,$at
1960#    sw $t4,-8($s7) # ... and store back into -8 header-word
1964:  skipMask_intToChar:

    # store data in string
1964#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
1968#    li $t0,-1
1972#    sw $t0,-4($s7)

    # we're returning $s7
1976#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
1980#    lw $ra,4($sp)
1984#    addu $sp,$sp,8

    # return
1988#    jr $ra

########################################################
# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
1992:mth_compareTo_String:
    # get string pointers and check parameter for null
1992#    lw $t0,($sp) # second string
1996#    beq $t0,$zero,nullPtrException
2000#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
2004#    lw $t2,-4($t0) # negative length of second string
2008#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
2012#    slt $t4,$t3,$t2
2016#    slt $t5,$t2,$t3
2020#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
2024#    lw $t2,-8($t0) # # data words in second string
2028#    lw $t3,-8($t1) # # data words in first string
2032#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
2036#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
2040#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
2044#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
2048#    beq $zero,$t5,skipStrCmpLenzz
2052#    move $t2,$t3
2056:  skipStrCmpLenzz:
2056#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
2060:  cmpLoopzz:
2060#    lw $t3,-8($t1) # word from str2
2064#    lw $t4,-8($t0) # word from str1
2068#    bne $t3,$t4,cmpNotEqualzz
2072#    addu $t1,$t1,4
2076#    addu $t0,$t0,4
2080#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
2084#    j cmpHitLimitzz

2088:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
2088#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
2092#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
2096#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
2100:  cmpHitLimitzz:
2100#    move $t0, $t5 # store return value
2104#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
2108:readLogicalChar:

    # check if we already have a character
2108#    lw $v0,lastCharRead
2112#    li $t0,-2
2116#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
2120#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2124#    jr $ra # return
    
2128:  doReadCh:
    # we need to actually read a character: read and return
2128#    li $v0,12 # use system call to read a character
2132#    syscall
2136#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
2140:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
2140#    blt $s7,$zero arraySizeOutOfBounds
2141##...slt $at,$s7,$zero
2145##...bne $at,$zero,3172

    # mark the fact that we have not yet GC'd for this allocation
2148#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

2152:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
2152#    addu $t0,$s6,$s7
2156#    sll $t0,$t0,2
2160#    addu $t0,$t0,8 # amount of memory needed
2164#    addu $t1,$t0,$s3
2168#    bgtu $t1,$s4,doGC
2169##...sltu $at,$s4,$t1
2173##...bne $at,$zero,2296

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
2176#    move $t2,$s3
2180:  zeroObjLoop:
2180#    sw $zero,($s3)
2184#    lw $zero,($s3)

2188#    addu $s3,4
2192#    bltu $s3,$t1,zeroObjLoop
2193##...sltu $at,$s3,$t1
2197##...bne $at,$zero,2180

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
2200#    sll $t0,$s7,2    # number of post-header bytes
2204#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
2208#    li $t2,255
2212#    bgeu $s6,$t2 firstHeaderLarge
2213##...sltu $at,$s6,$t2
2217##...beq $at,$zero,2264
2220#    lw $t1,prevHashConstant
2224#    addu $t1,0x12b68fd2
2225##...lui $at,4791
2229##...addiu $at,$at,-28718
2233##...addu $t1,$at,$t1
2236#    sw $t1,prevHashConstant # update hash constant
2240#    or $t1,0x80000000 # set top bit
2241##...lui $at,32768
2245##...or $t1,$at,$t1
2248#    and $t1,0xffffff00 # clear low bit
2249##...lui $at,65535
2253##...ori $at,$at,0xff00
2257##...and $t1,$t1,$at
2260#    or $s6,$t1
2264:firstHeaderLarge:
2264#    sw $s6,-8($t0) # store header-1 value
2268#    lw $zero,-8($t0)

    # store second header-value
2272#    sw $s7,-4($t0)   # second header-word
2276#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
2280#    move $s7,$t0
2284#    subu $sp,$sp,4
2288#    sw $t0,($sp)

2292#    jr $ra
    
2296:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
2296#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
2300#    lw $t5,gcCount
2304#    addu $t5,1
2308#    sw $t5,gcCount

    # save $s2 (our only rooted register) on the stack
    # so that the garbage collector processes it
2312#    subu $sp,$sp,4
2316#    sw $s2,($sp)

    # set $s3 to the address of the new segment and the
    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
2320#    lw $t0,cur_seg
2324#    move $t7,$s4
2328#    la $t6,seg1_start
2329##...lui $t6,16
2333##...addiu $t6,$t6,3756
2336#    la $s3,seg0_start
2340#    la $s4,seg0_end
2341##...lui $s4,16
2345##...addiu $s4,$s4,3756
2348#    sw $zero,cur_seg
2352#    bne $t0,$zero,skipGc1
2356#    la $t6,seg0_start
2360#    la $s3,seg1_start
2361##...lui $s3,16
2365##...addiu $s3,$s3,3756
2368#    la $s4,seg1_end
2369##...lui $s4,32
2373##...addiu $s4,$s4,3756
2376#    sw $s5,cur_seg
2380:  skipGc1:
2380#    li $t5,0x80000000
2384#    lw $t0,stack_bottom
2388#    subu $t0,4


    ###############################################################
    # at this point:
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first address of the target space
    # - $s4 contains the limit address of the target space
    # - cur_seg has been updated to refer to the target space
    # - $t0 contains the address of the deepest stack element
    # - $sp contains the address of the top stack element
    # - $s2 is available for use, having been pushed onto the stack
    # - $t5 contains the value 0x80000000
    ###############################################################

    ###### begin outer loop to copy all stack-direct objects ######

2392:  gcStackCopyLoop:
2392#    lw $t1,($t0) # current stack element

    # test if we have a GC tag
2396#    sll $t2,$t1,31 # zero iff low bit was zero
2400#    bne $t2,$zero,gcBump # go skip data values if low bit not zero

    # bump stack-address pointer
2404#    subu $t0,$t0,4

    # if value is out of range (which includes null=0), and is
    # therefore does not refer to an object on the heap, just go
    # loop back and do the next one
2408#    bleu $t1,$t6,gcTestIterDone1
2409##...sltu $at,$t6,$t1
2413##...beq $at,$zero,2576
2416#    bgtu $t1,$t7,gcTestIterDone1
2417##...sltu $at,$t7,$t1
2421##...bne $at,$zero,2576

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
2424#    lw $t2,-8($t1) # possible forwarding tag
