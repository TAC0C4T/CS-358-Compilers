.data
3512:strLit_17:
.asciiz " ... \n"
.align 2
.text
.globl main
0:main:
0#  jal vm_init
4#  li $v0, 10
8#  syscall
12:mth_main_Main:
12#  li $t0, 321
16#  subu $sp, $sp, 8
20#  sw $s5, 4($sp)
24#  sw $t0, 0($sp)
28#  li $t0, 18
32#  subu $sp, $sp, 8
36#  sw $s5, 4($sp)
40#  sw $t0, 0($sp)
44#  lw $t2, ($sp)
48#  addu $sp, $sp, 4
52#  lw $t1, ($sp)
56#  addu $sp, $sp, 4
60#  addu $t0, $t1, $t2
64#  subu $sp, $sp, 4
68#  sw $t0, ($sp)
72#  li $t0, 23
76#  subu $sp, $sp, 8
80#  sw $s5, 4($sp)
84#  sw $t0, 0($sp)
88#  lw $t2, ($sp)
92#  addu $sp, $sp, 4
96#  lw $t1, ($sp)
100#  addu $sp, $sp, 4
104#  subu $t0, $t1, $t2
108#  subu $sp, $sp, 4
112#  sw $t0, ($sp)
116#  la $t0, strLit_17
120#  subu $sp, $sp, 4
124#  sw $t0, ($sp)
128#  li $t0, 29
132#  subu $sp, $sp, 8
136#  sw $s5, 4($sp)
140#  sw $t0, 0($sp)
144#  lw $t2, ($sp)
148#  addu $sp, $sp, 4
152#  lw $t1, ($sp)
156#  addu $sp, $sp, 4
160#  addu $t0, $t1, $t2
164#  subu $sp, $sp, 4
168#  sw $t0, ($sp)
172#  subu $sp, $sp, 4
176#  sw $s2, ($sp)
180#  subu $sp, $sp, 4
184#  sw $s2, ($sp)
188#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
192:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
192#    lw $t0,-8($s2) # get word with hash bits from this
196#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
200#    addu $t0,$t1

204#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
208:mth_equals_Object:
208#    move $t0,$s2 # first pointer (this)
212#    lw $t1,($sp) # second pointer
216#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
217##...subu $at,$t0,$t1
221##...sltiu $t0,$at,1

224#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
228:mth_hashCode_String:
228#    move $t0,$s2 # put this pointer in t0

232#    li $t2,0 # current hash value
236#    lw $t1,-4($t0) # negative of number of characters in string
240#    beq $t1,$zero,done_hashCode_String # if zero length => done
244#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
248#    and $t0,0xfffffffc # adjust for padding
249##...lui $at,65535
253##...ori $at,$at,0xfffc
257##...and $t0,$t0,$at
260#    subu $t1,$t0,$t1 # address at end of string +12
264:loop_hashCode_String:    
264#    sll $t4,$t2,5 # multiply by 32
268#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
272#    lbu $t3,-12($t0) # current character
276#    addu $t2,$t3 # add in current character
280#    addu $t0,1 # go to next character's address
284#    bne $t0,$t1,loop_hashCode_String # loop back if more
288:done_hashCode_String:    

    # push int on stack
288#    move $t0, $t2 # put $t2 in return slot
292#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
296:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
296#    subu $sp,4
300#    sw $ra,($sp)
    
    # get hash value
304#    lw $t2,-12($s2) # vtable address
308#    lw $t0,($t2) # method address
312#    jalr $t0
316#    subu $sp,8 # push result (int in $t0) on stack
320#    sw $s5,4($sp)
324#    sw $t0,($sp)

    # compute print-size of hash value
328#    li $t0, 1
332#    lw $t1, ($sp)
336#    srl $t1,$t1,4
340#    beq $t1,$zero,toString_skip_loop
344:toString_loop_top:
344#    addu $t0,1
348#    srl $t1,$t1,4
352#    bne $t1,$zero,toString_loop_top
356:toString_skip_loop:
356#    subu $sp,8
360#    sw $s5,4($sp)
364#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
368#    lw $t2,-12($s2) # vtable address
372#    move $t0,$t2
376:toString_checkTagBit:
376#    subu $t0,1
380#    lb $t1,($t0)
384#    and $t1,0x80
385##...lui $at,0
389##...ori $at,$at,0x80
393##...and $t1,$t1,$at
396#    beq $t1,$zero,toString_checkTagBit
400#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
404#    subu $sp,8
408#    sw $t1,($sp)
412#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
416#    move $s7,$zero # -4 offset header word
420#    lw $t4,8($sp) # bytes for hash value
424#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
428#    addu $t4,8
432#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
436#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

440#    li $t0,CLASS_String # store string vtable address into ...
444#    sw $t0,-12($s7) # ... -12 offset in object header
448#    lw $t2,-12($s2) # our object's vtable address
452#    lw $t5,4($sp) # number characters in prefix
456#    lw $t1,12($sp) # number of characters in hashcode
460#    addu $t3,$t1,$t5 # number of characters in string ...
464#    addu $t3,1 # ... including the '@' character
468#    subu $t0,$zero,$t3 # store negated length into ...
472#    sw $t0,-4($s7) # ... -4 offset header word
476#    lw $t0,-8($s7) # get -8 offset header-word
480#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
481##...slt $at,$t0,$zero
485##...beq $at,$zero,504
488#    and $t0,0xff # mask off object's hash value ...
489##...lui $at,0
493##...ori $at,$at,0xff
497##...and $t0,$t0,$at
500#    sw $t0,-8($s7) # ... and store back into -8 header-word
504:skipMask_toString:
504#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
508#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
512#    subu $t4,$t2,$t5
516:toString_copyLoop:    
516#    lb $t3,($t4)
520#    and $t3,0x7f # mask off sign bit (in case first word)
521##...lui $at,0
525##...ori $at,$at,0x7f
529##...and $t3,$t3,$at
532#    sb $t3,-8($t0)
536#    addu $t4,1
540#    addu $t0,1
544#    blt $t4,$t2,toString_copyLoop
545##...slt $at,$t4,$t2
549##...bne $at,$zero,516

    # copy the '@' sign
552#    li $t3,'@'
556#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
560#    addu $t2,$t0,$t1 # address of last byte in string to store +8
564#    lw $t3,20($sp) # hash code to print
568:toString_hashCopyLoop:
568#    and $t4,$t3,0xf
572#    srl $t3,4
576#    lb $t4,hexChars($t4)
580#    sb $t4,-8($t2)
584#    subu $t2,$t2,1
588#    bgt $t2,$t0,toString_hashCopyLoop
589##...slt $at,$t0,$t2
593##...bne $at,$zero,568

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
596#    addu $sp,28
600#    lw $ra,($sp)
604#    addu $sp,4
608#    move $t0, $s7 # return string we created
612#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
616:mth_equals_String:
    
    # quick test for obvious false
616#    lw $t0,($sp) # second parameter
620#    beq $t0,$zero,goEsFalse # go return false if null
624#    lw $t1,-12($t0) # vtable pointer
628#    la $t2,CLASS_String # string vtable pointer
632#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
636#    subu $sp,12
640#    sw $ra,8($sp)
644#    sw $s2,4($sp)
648#    sw $t0,($sp)
652#    jal mth_compareTo_String
656#    lw $s2, 4($sp) #restore this pointer and pop parameters
660#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
664#    seq $t0,$t0,$zero
665##...subu $at,$t0,$zero
669##...sltiu $t0,$at,1

    # pop return address and return $t0
672#    lw $ra,($sp)
676#    addu $sp,4

680#    jr $ra # return
    
684:goEsFalse:
    # put 0 in $t0 and return
684#    li $t0, 0
688#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
692:mth_toString_String:
    #we are a string, so return this.
692#    move $t0, $s2
696#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
700:mth_readLine_Lib:
    
700#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
704#    sw $ra, 4($sp) # save $ra
708#    move $t1,$sp # save "original" sp

712:  doRead:

    # read the character
712#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
716#    subu $t2,$v0,13
720#    bne $t2,$zero,notReturnRL
724#    jal readLogicalChar
728#    subu $t2,$v0,10 # check for newline
732#    beq $t2,$zero,foundNewLine
736#    sw $v0,lastCharRead # push back character into queue
740#    j foundNewLine # go process the line

744:  notReturnRL:

    # at this point, $v0 has our character

744#    subu $t0,$v0,10
748#    beq $t0,$zero,foundNewLine
752#    blt $v0,$zero,foundEof
753##...slt $at,$v0,$zero
