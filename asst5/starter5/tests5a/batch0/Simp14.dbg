#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3168:instanceOf:
    # get object, go return false if null
3168#    lw $t2,($sp)
3172#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3176#    lw $t2,-12($t2) # vtable address
3180#    sge $t0,$t2,$t0 # are we >= the lower limit?
3181##...slt $t0,$t2,$t0
3185##...xori $t0,$t0,0x1
3188#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3192#    and $t2,$t0,$t1
3196#    sw $t2,($sp)
3200:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3200#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3204:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3204#    li $v0,4 # syscall-code for print-string
3208#    syscall
3212:exit:
    # print termination message
3212#    li $v0,4 # syscall-code for print-string
3216#    la $a0,exitString
3220#    syscall

    # print number of garbage collections
3224#    li $v0,4 # syscall-code for print-string
3228#    la $a0,gcCountMsg
3232#    syscall # print "Number of ..."
3236#    lw $a0,gcCount # number of GC's
3240#    li $v0,1 # code for print-int
3244#    syscall
3248#    li $v0,4 # syscall-code for print-string
3252#    la $a0,newlineString
3256#    syscall # print newline

    # terminate execution
3260#    li $v0,10 #syscall-code for "exit"
3264#    syscall

3268:outOfHeapMemory:
3268#    la $a0,heapMemoryMsg
3272#    j exitError
3276:divByZeroError:
3276#    la $a0,divByZeroMsg
3280#    j exitError
3284:strIndexOutOfBounds:
3284#    la $a0,strIndexOutOfBoundsMsg
3288#    j exitError
3292:arrayIndexOutOfBounds:
3292#    la $a0,arrayIndexOutOfBoundsMsg
3296#    j exitError
3300:arraySizeOutOfBounds:
3300#    la $a0,arraySizeOutOfBoundsMsg
3304#    j exitError
3308:nullPtrException:
3308#    la $a0,nullPtrExceptionMsg
3312#    j exitError
3316:badIntegerFormat:
3316#    la $a0,badIntegerFormatMsg
3320#    j exitError
3324:castException:
3324#    la $a0,castExceptionMsg
3328#    j exitError
############## data section ################
    .data
3520:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3536:cur_seg:
    .word 0

3540:lastCharRead:
    .word -2 # -2 => no buffered character
3544:prevHashConstant:
    .word 0x2785173c
3548:gcCount:
    .word 0

3552:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3579:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3602:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3637:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3671:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3704:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3735:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3783:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3804:gcMsg: 
      .asciiz "\nGC!\n"
3810:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3842:nullStr:
    .asciiz "null"
3847:trueString:
    .asciiz "true"
3852:falseString:
    .asciiz "false"
3858:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
3886:newlineString:
    .asciiz "\n"
    
    .align 2
3888:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3892:seg0_start:
    .space 0x100000
1052468:seg0_end:
1052468:seg1_start:
