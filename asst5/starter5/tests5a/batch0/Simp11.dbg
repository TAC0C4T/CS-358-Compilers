841##...slt $at,$zero,$t0
845##...bne $at,$zero,888
848#    beq $t0,$zero,riSkipWhiteLoop # start over if space
852#    subu $t0,$v0,10
856#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
860#    subu $t0,$v0,9
864#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
868#    subu $t0,$v0,13
872#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
876#    subu $t0,$v0,12
880#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
884#    j badIntegerFormat # illegal integer char: abort program

888:  nonWhite:
888#    subu $t0,$v0,'-'
892#    li $t4,1 # final multiplier
896#    bne $t0,$zero,helpReadInt # go read
900#    li $t4,-1 # -1 in final multiplier
