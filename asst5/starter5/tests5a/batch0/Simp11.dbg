# str.charAt(n) - library method (class String)
# accesses a character in a string, as in Java
# - parameters:
#   - ($sp) - the index, n
#   - 4($sp) - GC tag
#   - 8($sp) - old this pointer
#   - $s2    - this pointer
# - returns:
#   - $t0 - the character found.
########################################################
1628:mth_charAt_String:
    # get string
1628#    move $t0,$s2

    # check that index is in bounds
1632#    lw $t1,-4($t0) # negative of # data words in string
1636#    subu $t3,$zero,$t1 # # chars in string
1640#    lw $t2,($sp) # index
1644#    bgeu $t2,$t3,strIndexOutOfBounds
1645##...sltu $at,$t2,$t3
1649##...beq $at,$zero,3172

    # access element
1652#    lw $t1,-8($t0) # # data words in object
1656#    sll $t1,$t1,2 # - byte-offset from end of chars
1660#    subu $t1,$t2,$t1 # - address of first char in string, offset by 8
1664#    addu $t0,$t0,$t1 # - address of our char, offset by 8
1668#    lb $t0,-8($t0) # our char

    # return
1672#    jr $ra
