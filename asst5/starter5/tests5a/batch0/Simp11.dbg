########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
1920:mth_intToChar_Lib:
    # save return address
1920#    subu $sp,$sp,4
1924#    sw $ra,($sp)

    # allocate object
1928#    li $s6,2
1932#    move $s7,$zero
1936#    jal newObject

    # get n from string.
1940#    lw $t1,8($sp)

    # store "String" tag into class field
1944#    la $t0,CLASS_String
1948#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
1952#    lw $t4,-8($s7) # # data words in source string
1956#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
1957##...slt $at,$t4,$zero
1961##...beq $at,$zero,1980
1964#    and $t4,0xff # mask off object's hash value ...
1965##...lui $at,0
1969##...ori $at,$at,0xff
1973##...and $t4,$t4,$at
1976#    sw $t4,-8($s7) # ... and store back into -8 header-word
1980:  skipMask_intToChar:

    # store data in string
1980#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
1984#    li $t0,-1
1988#    sw $t0,-4($s7)

    # we're returning $s7
1992#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
1996#    lw $ra,4($sp)
2000#    addu $sp,$sp,8

    # return
2004#    jr $ra
