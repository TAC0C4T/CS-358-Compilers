########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
1676:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
1676#    subu $sp,$sp,8
1680#    sw $ra,4($sp)

    # save current sp
1684#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
1688#    li $t3,10

    # get argument, negate if negative
1692#    lw $t1,8($sp)
1696#    bge $t1,$zero,itsNonNegLoop
1697##...slt $at,$t1,$zero
1701##...beq $at,$zero,1708
1704#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
1708:  itsNonNegLoop:
1708#    divu $t1,$t3
1712#    mflo $t1 # quotient
1716#    mfhi $t4 # remainder
1720#    addu $t4,$t4,'0' # turn remainder into digit
1724#    subu $sp,$sp,4
1728#    sw $t4,($sp) # push digit onto stack
1732#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
1736#    lw $t4,8($t0)
1740#    bge $t4,$zero,itsSkipNeg
1741##...slt $at,$t4,$zero
1745##...beq $at,$zero,1760
1748#    li $t4,'-'
1752#    subu $sp,$sp,4
1756#    sw $t4,($sp)
1760:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
1760#    subu $s6,$t0,$sp
1764#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
1768#    sw $t3,($t0)
1772#    srl $s6,$s6,2
1776#    subu $sp,$sp,4
1780#    sw $s6,($sp)
    
    # allocate memory
1784#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
1788#    srl $s6,$s6,2
1792#    move $s7,$zero # no "object" words in object
