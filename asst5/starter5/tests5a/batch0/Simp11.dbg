    # lower limit, and if we're < the higher limit
3064#    lw $t2,-12($t2) # vtable address
3068#    sge $t0,$t2,$t0 # are we >= the lower limit?
3069##...slt $t0,$t2,$t0
3073##...xori $t0,$t0,0x1
3076#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3080#    and $t2,$t0,$t1
3084#    sw $t2,($sp)
3088:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3088#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3092:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3092#    li $v0,4 # syscall-code for print-string
3096#    syscall
3100:exit:
    # print termination message
3100#    li $v0,4 # syscall-code for print-string
3104#    la $a0,exitString
3108#    syscall

    # print number of garbage collections
3112#    li $v0,4 # syscall-code for print-string
3116#    la $a0,gcCountMsg
3120#    syscall # print "Number of ..."
3124#    lw $a0,gcCount # number of GC's
3128#    li $v0,1 # code for print-int
3132#    syscall
3136#    li $v0,4 # syscall-code for print-string
3140#    la $a0,newlineString
3144#    syscall # print newline

    # terminate execution
3148#    li $v0,10 #syscall-code for "exit"
3152#    syscall

3156:outOfHeapMemory:
3156#    la $a0,heapMemoryMsg
3160#    j exitError
3164:divByZeroError:
3164#    la $a0,divByZeroMsg
3168#    j exitError
3172:strIndexOutOfBounds:
3172#    la $a0,strIndexOutOfBoundsMsg
3176#    j exitError
3180:arrayIndexOutOfBounds:
3180#    la $a0,arrayIndexOutOfBoundsMsg
3184#    j exitError
3188:arraySizeOutOfBounds:
3188#    la $a0,arraySizeOutOfBoundsMsg
3192#    j exitError
3196:nullPtrException:
3196#    la $a0,nullPtrExceptionMsg
3200#    j exitError
3204:badIntegerFormat:
3204#    la $a0,badIntegerFormatMsg
3208#    j exitError
3212:castException:
3212#    la $a0,castExceptionMsg
3216#    j exitError
############## data section ################
    .data
3400:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3416:cur_seg:
    .word 0

3420:lastCharRead:
    .word -2 # -2 => no buffered character
3424:prevHashConstant:
    .word 0x2785173c
3428:gcCount:
    .word 0

3432:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3459:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3482:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3517:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3551:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3584:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3615:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3663:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3684:gcMsg: 
      .asciiz "\nGC!\n"
3690:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3722:nullStr:
    .asciiz "null"
3727:trueString:
    .asciiz "true"
3732:falseString:
    .asciiz "false"
3738:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
