941##...beq $at,$zero,960

944#    mul $t3,$t3,$t2 # multiply old value by 10
945##...mult $t3,$t2
949##...mflo $t3
952#    addu $t3,$t3,$t1 # add in value of new digit
956#    j digitLoop

960:  doneDigitLoop:
