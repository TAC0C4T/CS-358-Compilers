0:main:
0#  jal vm_init
4#  li $s6, 1
8#  li $s7, 0
12#  jal newObject
16#  la $t0, CLASS_Main
20#  sw $t0, -12($s7)
24#  addu $sp,$sp,4
28#  move $s2, $s7
32#  jal mth_main_Main
36#  li $v0, 10
40#  syscall
44:mth_main_Main:
44#  li $t0, 27
48#  subu $sp, $sp, 8
52#  sw $s5, 4($sp)
56#  sw $t0, 0($sp)
60#  li $t0, 263
64#  subu $sp, $sp, 8
68#  sw $s5, 4($sp)
72#  sw $t0, 0($sp)
76#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
80:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
80#    lw $t0,-8($s2) # get word with hash bits from this
84#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
88#    addu $t0,$t1

92#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
96:mth_equals_Object:
96#    move $t0,$s2 # first pointer (this)
100#    lw $t1,($sp) # second pointer
104#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
105##...subu $at,$t0,$t1
109##...sltiu $t0,$at,1

112#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
116:mth_hashCode_String:
116#    move $t0,$s2 # put this pointer in t0

120#    li $t2,0 # current hash value
124#    lw $t1,-4($t0) # negative of number of characters in string
128#    beq $t1,$zero,done_hashCode_String # if zero length => done
132#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
136#    and $t0,0xfffffffc # adjust for padding
137##...lui $at,65535
141##...ori $at,$at,0xfffc
145##...and $t0,$t0,$at
148#    subu $t1,$t0,$t1 # address at end of string +12
152:loop_hashCode_String:    
152#    sll $t4,$t2,5 # multiply by 32
156#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
160#    lbu $t3,-12($t0) # current character
164#    addu $t2,$t3 # add in current character
168#    addu $t0,1 # go to next character's address
172#    bne $t0,$t1,loop_hashCode_String # loop back if more
176:done_hashCode_String:    

    # push int on stack
176#    move $t0, $t2 # put $t2 in return slot
180#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
184:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
184#    subu $sp,4
188#    sw $ra,($sp)
    
    # get hash value
192#    lw $t2,-12($s2) # vtable address
196#    lw $t0,($t2) # method address
200#    jalr $t0
204#    subu $sp,8 # push result (int in $t0) on stack
208#    sw $s5,4($sp)
212#    sw $t0,($sp)

    # compute print-size of hash value
216#    li $t0, 1
220#    lw $t1, ($sp)
224#    srl $t1,$t1,4
228#    beq $t1,$zero,toString_skip_loop
232:toString_loop_top:
232#    addu $t0,1
236#    srl $t1,$t1,4
240#    bne $t1,$zero,toString_loop_top
244:toString_skip_loop:
244#    subu $sp,8
248#    sw $s5,4($sp)
252#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
256#    lw $t2,-12($s2) # vtable address
260#    move $t0,$t2
264:toString_checkTagBit:
264#    subu $t0,1
268#    lb $t1,($t0)
272#    and $t1,0x80
273##...lui $at,0
277##...ori $at,$at,0x80
281##...and $t1,$t1,$at
284#    beq $t1,$zero,toString_checkTagBit
288#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
292#    subu $sp,8
296#    sw $t1,($sp)
300#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
304#    move $s7,$zero # -4 offset header word
308#    lw $t4,8($sp) # bytes for hash value
312#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
316#    addu $t4,8
320#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
324#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

328#    li $t0,CLASS_String # store string vtable address into ...
332#    sw $t0,-12($s7) # ... -12 offset in object header
336#    lw $t2,-12($s2) # our object's vtable address
340#    lw $t5,4($sp) # number characters in prefix
344#    lw $t1,12($sp) # number of characters in hashcode
348#    addu $t3,$t1,$t5 # number of characters in string ...
352#    addu $t3,1 # ... including the '@' character
356#    subu $t0,$zero,$t3 # store negated length into ...
360#    sw $t0,-4($s7) # ... -4 offset header word
364#    lw $t0,-8($s7) # get -8 offset header-word
368#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
369##...slt $at,$t0,$zero
373##...beq $at,$zero,392
376#    and $t0,0xff # mask off object's hash value ...
377##...lui $at,0
381##...ori $at,$at,0xff
385##...and $t0,$t0,$at
388#    sw $t0,-8($s7) # ... and store back into -8 header-word
392:skipMask_toString:
392#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
396#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
400#    subu $t4,$t2,$t5
404:toString_copyLoop:    
404#    lb $t3,($t4)
408#    and $t3,0x7f # mask off sign bit (in case first word)
409##...lui $at,0
413##...ori $at,$at,0x7f
417##...and $t3,$t3,$at
420#    sb $t3,-8($t0)
424#    addu $t4,1
428#    addu $t0,1
432#    blt $t4,$t2,toString_copyLoop
433##...slt $at,$t4,$t2
437##...bne $at,$zero,404

    # copy the '@' sign
440#    li $t3,'@'
444#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
448#    addu $t2,$t0,$t1 # address of last byte in string to store +8
452#    lw $t3,20($sp) # hash code to print
456:toString_hashCopyLoop:
456#    and $t4,$t3,0xf
460#    srl $t3,4
464#    lb $t4,hexChars($t4)
468#    sb $t4,-8($t2)
472#    subu $t2,$t2,1
476#    bgt $t2,$t0,toString_hashCopyLoop
477##...slt $at,$t0,$t2
481##...bne $at,$zero,456

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
484#    addu $sp,28
488#    lw $ra,($sp)
492#    addu $sp,4
496#    move $t0, $s7 # return string we created
500#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
504:mth_equals_String:
    
    # quick test for obvious false
504#    lw $t0,($sp) # second parameter
508#    beq $t0,$zero,goEsFalse # go return false if null
512#    lw $t1,-12($t0) # vtable pointer
516#    la $t2,CLASS_String # string vtable pointer
520#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
524#    subu $sp,12
528#    sw $ra,8($sp)
532#    sw $s2,4($sp)
536#    sw $t0,($sp)
540#    jal mth_compareTo_String
544#    lw $s2, 4($sp) #restore this pointer and pop parameters
548#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
552#    seq $t0,$t0,$zero
553##...subu $at,$t0,$zero
557##...sltiu $t0,$at,1

    # pop return address and return $t0
560#    lw $ra,($sp)
564#    addu $sp,4

568#    jr $ra # return
    
572:goEsFalse:
    # put 0 in $t0 and return
572#    li $t0, 0
576#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
580:mth_toString_String:
    #we are a string, so return this.
580#    move $t0, $s2
584#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
588:mth_readLine_Lib:
    
588#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
592#    sw $ra, 4($sp) # save $ra
596#    move $t1,$sp # save "original" sp

600:  doRead:

    # read the character
600#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
604#    subu $t2,$v0,13
608#    bne $t2,$zero,notReturnRL
612#    jal readLogicalChar
616#    subu $t2,$v0,10 # check for newline
620#    beq $t2,$zero,foundNewLine
624#    sw $v0,lastCharRead # push back character into queue
628#    j foundNewLine # go process the line

632:  notReturnRL:

    # at this point, $v0 has our character

632#    subu $t0,$v0,10
636#    beq $t0,$zero,foundNewLine
640#    blt $v0,$zero,foundEof
641##...slt $at,$v0,$zero
645##...bne $at,$zero,660

    # we have a character, so push it onto stack
648#    subu $sp,$sp,4
652#    sw $v0,($sp)

    # loop back up to get next character
656#    j doRead

660:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
660#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
664#    li $s7, 0 # return-value: null
668#    j rlReturn # return

672:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
672#    subu $t0,$t1,$sp # number of chars we read (times 4)
676#    srl $s6,$t0,2 # number of words on stack with chars
680#    subu $sp,$sp,4 # push char-count ...
684#    sw $s6,($sp) # ... onto stack
688#    addu $t2,$t0,5 # GC tag, incl. for count-word
692#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
