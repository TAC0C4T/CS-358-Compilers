
    # determine if we have enough memory available
2128#    addu $t0,$s6,$s7
2132#    sll $t0,$t0,2
2136#    addu $t0,$t0,8 # amount of memory needed
2140#    addu $t1,$t0,$s3
2144#    bgtu $t1,$s4,doGC
