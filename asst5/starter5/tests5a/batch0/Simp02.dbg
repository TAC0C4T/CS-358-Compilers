812#    subu $t0,$v0,10
816#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
820#    subu $t0,$v0,9
824#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
828#    subu $t0,$v0,13
832#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
836#    subu $t0,$v0,12
840#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
844#    j badIntegerFormat # illegal integer char: abort program
