2217##...lui $at,32768
2221##...or $t1,$at,$t1
2224#    and $t1,0xffffff00 # clear low bit
2225##...lui $at,65535
2229##...ori $at,$at,0xff00
2233##...and $t1,$t1,$at
2236#    or $s6,$t1
2240:firstHeaderLarge:
2240#    sw $s6,-8($t0) # store header-1 value
2244#    lw $zero,-8($t0)

    # store second header-value
2248#    sw $s7,-4($t0)   # second header-word
2252#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
2256#    move $s7,$t0
2260#    subu $sp,$sp,4
2264#    sw $t0,($sp)
