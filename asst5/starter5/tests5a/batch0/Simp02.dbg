.globl main
0:main:
0#  jal vm_init
4#  li $v0, 10
8#  syscall
12:mth_main_Main:
12#  li $t0, 345
16#  subu $sp, $sp, 8
20#  sw $s5, 4($sp)
24#  sw $t0, 0($sp)
28#  subu $sp, $sp, 4
32#  sw $s2, ($sp)
36#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
40:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
40#    lw $t0,-8($s2) # get word with hash bits from this
44#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
48#    addu $t0,$t1

52#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
56:mth_equals_Object:
56#    move $t0,$s2 # first pointer (this)
60#    lw $t1,($sp) # second pointer
64#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
65##...subu $at,$t0,$t1
69##...sltiu $t0,$at,1

72#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
76:mth_hashCode_String:
76#    move $t0,$s2 # put this pointer in t0

80#    li $t2,0 # current hash value
84#    lw $t1,-4($t0) # negative of number of characters in string
88#    beq $t1,$zero,done_hashCode_String # if zero length => done
92#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
96#    and $t0,0xfffffffc # adjust for padding
97##...lui $at,65535
101##...ori $at,$at,0xfffc
105##...and $t0,$t0,$at
108#    subu $t1,$t0,$t1 # address at end of string +12
112:loop_hashCode_String:    
112#    sll $t4,$t2,5 # multiply by 32
116#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
120#    lbu $t3,-12($t0) # current character
124#    addu $t2,$t3 # add in current character
128#    addu $t0,1 # go to next character's address
132#    bne $t0,$t1,loop_hashCode_String # loop back if more
136:done_hashCode_String:    

    # push int on stack
136#    move $t0, $t2 # put $t2 in return slot
140#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
144:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
144#    subu $sp,4
148#    sw $ra,($sp)
    
    # get hash value
152#    lw $t2,-12($s2) # vtable address
156#    lw $t0,($t2) # method address
160#    jalr $t0
164#    subu $sp,8 # push result (int in $t0) on stack
168#    sw $s5,4($sp)
172#    sw $t0,($sp)

    # compute print-size of hash value
176#    li $t0, 1
180#    lw $t1, ($sp)
184#    srl $t1,$t1,4
188#    beq $t1,$zero,toString_skip_loop
192:toString_loop_top:
192#    addu $t0,1
196#    srl $t1,$t1,4
200#    bne $t1,$zero,toString_loop_top
204:toString_skip_loop:
204#    subu $sp,8
208#    sw $s5,4($sp)
212#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
216#    lw $t2,-12($s2) # vtable address
220#    move $t0,$t2
224:toString_checkTagBit:
224#    subu $t0,1
228#    lb $t1,($t0)
232#    and $t1,0x80
233##...lui $at,0
237##...ori $at,$at,0x80
241##...and $t1,$t1,$at
244#    beq $t1,$zero,toString_checkTagBit
248#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
252#    subu $sp,8
256#    sw $t1,($sp)
260#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
264#    move $s7,$zero # -4 offset header word
268#    lw $t4,8($sp) # bytes for hash value
272#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
276#    addu $t4,8
280#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
284#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

288#    li $t0,CLASS_String # store string vtable address into ...
292#    sw $t0,-12($s7) # ... -12 offset in object header
296#    lw $t2,-12($s2) # our object's vtable address
300#    lw $t5,4($sp) # number characters in prefix
304#    lw $t1,12($sp) # number of characters in hashcode
308#    addu $t3,$t1,$t5 # number of characters in string ...
312#    addu $t3,1 # ... including the '@' character
316#    subu $t0,$zero,$t3 # store negated length into ...
320#    sw $t0,-4($s7) # ... -4 offset header word
324#    lw $t0,-8($s7) # get -8 offset header-word
328#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
329##...slt $at,$t0,$zero
333##...beq $at,$zero,352
336#    and $t0,0xff # mask off object's hash value ...
337##...lui $at,0
341##...ori $at,$at,0xff
345##...and $t0,$t0,$at
348#    sw $t0,-8($s7) # ... and store back into -8 header-word
352:skipMask_toString:
352#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
356#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
360#    subu $t4,$t2,$t5
364:toString_copyLoop:    
364#    lb $t3,($t4)
368#    and $t3,0x7f # mask off sign bit (in case first word)
369##...lui $at,0
373##...ori $at,$at,0x7f
377##...and $t3,$t3,$at
380#    sb $t3,-8($t0)
384#    addu $t4,1
388#    addu $t0,1
392#    blt $t4,$t2,toString_copyLoop
393##...slt $at,$t4,$t2
397##...bne $at,$zero,364

    # copy the '@' sign
400#    li $t3,'@'
404#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
408#    addu $t2,$t0,$t1 # address of last byte in string to store +8
412#    lw $t3,20($sp) # hash code to print
416:toString_hashCopyLoop:
416#    and $t4,$t3,0xf
420#    srl $t3,4
424#    lb $t4,hexChars($t4)
428#    sb $t4,-8($t2)
432#    subu $t2,$t2,1
436#    bgt $t2,$t0,toString_hashCopyLoop
437##...slt $at,$t0,$t2
441##...bne $at,$zero,416

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
444#    addu $sp,28
448#    lw $ra,($sp)
452#    addu $sp,4
456#    move $t0, $s7 # return string we created
460#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
464:mth_equals_String:
    
    # quick test for obvious false
464#    lw $t0,($sp) # second parameter
468#    beq $t0,$zero,goEsFalse # go return false if null
472#    lw $t1,-12($t0) # vtable pointer
476#    la $t2,CLASS_String # string vtable pointer
480#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
484#    subu $sp,12
488#    sw $ra,8($sp)
492#    sw $s2,4($sp)
496#    sw $t0,($sp)
500#    jal mth_compareTo_String
504#    lw $s2, 4($sp) #restore this pointer and pop parameters
508#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
512#    seq $t0,$t0,$zero
513##...subu $at,$t0,$zero
517##...sltiu $t0,$at,1

    # pop return address and return $t0
520#    lw $ra,($sp)
524#    addu $sp,4

528#    jr $ra # return
    
532:goEsFalse:
    # put 0 in $t0 and return
532#    li $t0, 0
536#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
540:mth_toString_String:
    #we are a string, so return this.
540#    move $t0, $s2
544#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
548:mth_readLine_Lib:
    
548#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
552#    sw $ra, 4($sp) # save $ra
556#    move $t1,$sp # save "original" sp

560:  doRead:

    # read the character
560#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
564#    subu $t2,$v0,13
568#    bne $t2,$zero,notReturnRL
572#    jal readLogicalChar
576#    subu $t2,$v0,10 # check for newline
580#    beq $t2,$zero,foundNewLine
584#    sw $v0,lastCharRead # push back character into queue
588#    j foundNewLine # go process the line

592:  notReturnRL:

    # at this point, $v0 has our character

592#    subu $t0,$v0,10
596#    beq $t0,$zero,foundNewLine
600#    blt $v0,$zero,foundEof
601##...slt $at,$v0,$zero
605##...bne $at,$zero,620

    # we have a character, so push it onto stack
608#    subu $sp,$sp,4
612#    sw $v0,($sp)

    # loop back up to get next character
616#    j doRead

620:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
620#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
624#    li $s7, 0 # return-value: null
628#    j rlReturn # return

632:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
632#    subu $t0,$t1,$sp # number of chars we read (times 4)
636#    srl $s6,$t0,2 # number of words on stack with chars
640#    subu $sp,$sp,4 # push char-count ...
644#    sw $s6,($sp) # ... onto stack
648#    addu $t2,$t0,5 # GC tag, incl. for count-word
652#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
656#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
660#    srl $s6,$s6,2  # data words in object
664#    move $s7,$zero # object words in object
668#    jal newObject  # allocate space
    
    # store header words
672#    la $t0,CLASS_String
676#    sw $t0,-12($s7)# store class tag (String) into object
