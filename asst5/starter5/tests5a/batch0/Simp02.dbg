########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3016:instanceOf:
    # get object, go return false if null
3016#    lw $t2,($sp)
3020#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3024#    lw $t2,-12($t2) # vtable address
3028#    sge $t0,$t2,$t0 # are we >= the lower limit?
3029##...slt $t0,$t2,$t0
3033##...xori $t0,$t0,0x1
3036#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3040#    and $t2,$t0,$t1
3044#    sw $t2,($sp)
3048:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3048#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3052:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3052#    li $v0,4 # syscall-code for print-string
3056#    syscall
3060:exit:
    # print termination message
3060#    li $v0,4 # syscall-code for print-string
3064#    la $a0,exitString
3068#    syscall

    # print number of garbage collections
3072#    li $v0,4 # syscall-code for print-string
3076#    la $a0,gcCountMsg
3080#    syscall # print "Number of ..."
3084#    lw $a0,gcCount # number of GC's
3088#    li $v0,1 # code for print-int
3092#    syscall
3096#    li $v0,4 # syscall-code for print-string
3100#    la $a0,newlineString
3104#    syscall # print newline

    # terminate execution
3108#    li $v0,10 #syscall-code for "exit"
3112#    syscall

3116:outOfHeapMemory:
3116#    la $a0,heapMemoryMsg
3120#    j exitError
3124:divByZeroError:
3124#    la $a0,divByZeroMsg
3128#    j exitError
3132:strIndexOutOfBounds:
3132#    la $a0,strIndexOutOfBoundsMsg
3136#    j exitError
3140:arrayIndexOutOfBounds:
3140#    la $a0,arrayIndexOutOfBoundsMsg
3144#    j exitError
3148:arraySizeOutOfBounds:
3148#    la $a0,arraySizeOutOfBoundsMsg
3152#    j exitError
3156:nullPtrException:
3156#    la $a0,nullPtrExceptionMsg
3160#    j exitError
3164:badIntegerFormat:
3164#    la $a0,badIntegerFormatMsg
3168#    j exitError
3172:castException:
3172#    la $a0,castExceptionMsg
3176#    j exitError
############## data section ################
    .data
3360:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3376:cur_seg:
    .word 0

3380:lastCharRead:
    .word -2 # -2 => no buffered character
3384:prevHashConstant:
    .word 0x2785173c
3388:gcCount:
    .word 0

3392:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3419:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3442:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3477:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3511:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3544:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3575:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3623:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3644:gcMsg: 
      .asciiz "\nGC!\n"
3650:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3682:nullStr:
    .asciiz "null"
3687:trueString:
    .asciiz "true"
3692:falseString:
    .asciiz "false"
3698:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
3726:newlineString:
    .asciiz "\n"
    
    .align 2
3728:stack_bottom:
    .word 0

