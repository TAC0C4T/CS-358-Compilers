########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
2888:vm_init:

    # mark bottom of stack
2888#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
2892#    move $s2,$zero

    #set up the "five" register
2896#    li $s5,5

2900#    la $s3,seg0_start
2904#    la $s4,seg0_end
2905##...lui $s4,16
2909##...addiu $s4,$s4,3736
    
    # return
2912#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
2916:divide:
    # get parameters; abort if divisor zero
2916#    lw $t0,($sp)
2920#    lw $t1,8($sp)
2924#    beq $t0,$zero,divByZeroError
    
    # perform division
2928#    div $t1,$t0
2932#    mflo $t0

    # store result, adjust stack and return
2936#    addu $sp,$sp,8 # adjust stack
2940#    sw $t0,($sp) # store result
2944#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
2948:remainder:
    # get parameters; abort if divisor zero
2948#    lw $t0,($sp)
2952#    lw $t1,8($sp)
2956#    beq $t0,$zero,divByZeroError
    
    # perform division
2960#    div $t1,$t0
2964#    mfhi $t0

    # store result, adjust stack and return
2968#    addu $sp,$sp,8 # adjust stack
2972#    sw $t0,($sp) # store result
2976#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
2980:checkCast:
    # get object, allow immediately if null
2980#    lw $t2,($sp)
2984#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
2988#    lw $t2,-12($t2) # vtable address
2992#    bge $t2,$t1,castException
2993##...slt $at,$t2,$t1
2997##...beq $at,$zero,3168
3000#    blt $t2,$t0,castException
3001##...slt $at,$t2,$t0
3005##...bne $at,$zero,3168
    
    # return, leaving object unchanged on stack
3008:  checkCastReturn:    
3008#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    
