    # greater
2060#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
2064#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
2068#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
2072:  cmpHitLimitzz:
2072#    move $t0, $t5 # store return value
2076#    jr $ra # return
