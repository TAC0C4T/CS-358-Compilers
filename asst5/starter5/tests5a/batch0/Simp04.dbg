.data
3356:strLit_0:
.asciiz "Hello.\n"
.align 2
.text
.globl main
0:main:
0#  jal vm_init
4#  li $v0, 10
8#  syscall
12:mth_main_Main:
12#  la $t0, strLit_0
16#  subu $sp, $sp, 4
20#  sw $t0, ($sp)
24#  subu $sp, $sp, 4
28#  sw $s2, ($sp)
32#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
36:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
36#    lw $t0,-8($s2) # get word with hash bits from this
40#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
44#    addu $t0,$t1

48#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
52:mth_equals_Object:
52#    move $t0,$s2 # first pointer (this)
56#    lw $t1,($sp) # second pointer
60#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
61##...subu $at,$t0,$t1
65##...sltiu $t0,$at,1

68#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
72:mth_hashCode_String:
72#    move $t0,$s2 # put this pointer in t0

76#    li $t2,0 # current hash value
80#    lw $t1,-4($t0) # negative of number of characters in string
84#    beq $t1,$zero,done_hashCode_String # if zero length => done
88#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
92#    and $t0,0xfffffffc # adjust for padding
93##...lui $at,65535
97##...ori $at,$at,0xfffc
101##...and $t0,$t0,$at
104#    subu $t1,$t0,$t1 # address at end of string +12
108:loop_hashCode_String:    
108#    sll $t4,$t2,5 # multiply by 32
112#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
116#    lbu $t3,-12($t0) # current character
120#    addu $t2,$t3 # add in current character
124#    addu $t0,1 # go to next character's address
128#    bne $t0,$t1,loop_hashCode_String # loop back if more
132:done_hashCode_String:    

    # push int on stack
132#    move $t0, $t2 # put $t2 in return slot
136#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
140:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
140#    subu $sp,4
144#    sw $ra,($sp)
    
    # get hash value
148#    lw $t2,-12($s2) # vtable address
152#    lw $t0,($t2) # method address
156#    jalr $t0
160#    subu $sp,8 # push result (int in $t0) on stack
164#    sw $s5,4($sp)
168#    sw $t0,($sp)

    # compute print-size of hash value
172#    li $t0, 1
176#    lw $t1, ($sp)
180#    srl $t1,$t1,4
184#    beq $t1,$zero,toString_skip_loop
188:toString_loop_top:
188#    addu $t0,1
192#    srl $t1,$t1,4
196#    bne $t1,$zero,toString_loop_top
200:toString_skip_loop:
200#    subu $sp,8
204#    sw $s5,4($sp)
208#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
212#    lw $t2,-12($s2) # vtable address
216#    move $t0,$t2
220:toString_checkTagBit:
220#    subu $t0,1
224#    lb $t1,($t0)
228#    and $t1,0x80
229##...lui $at,0
233##...ori $at,$at,0x80
237##...and $t1,$t1,$at
240#    beq $t1,$zero,toString_checkTagBit
244#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
248#    subu $sp,8
252#    sw $t1,($sp)
256#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
260#    move $s7,$zero # -4 offset header word
264#    lw $t4,8($sp) # bytes for hash value
268#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
272#    addu $t4,8
276#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
280#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

284#    li $t0,CLASS_String # store string vtable address into ...
288#    sw $t0,-12($s7) # ... -12 offset in object header
292#    lw $t2,-12($s2) # our object's vtable address
296#    lw $t5,4($sp) # number characters in prefix
300#    lw $t1,12($sp) # number of characters in hashcode
304#    addu $t3,$t1,$t5 # number of characters in string ...
308#    addu $t3,1 # ... including the '@' character
312#    subu $t0,$zero,$t3 # store negated length into ...
316#    sw $t0,-4($s7) # ... -4 offset header word
320#    lw $t0,-8($s7) # get -8 offset header-word
324#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
325##...slt $at,$t0,$zero
329##...beq $at,$zero,348
332#    and $t0,0xff # mask off object's hash value ...
333##...lui $at,0
337##...ori $at,$at,0xff
341##...and $t0,$t0,$at
344#    sw $t0,-8($s7) # ... and store back into -8 header-word
348:skipMask_toString:
348#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
352#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
356#    subu $t4,$t2,$t5
360:toString_copyLoop:    
360#    lb $t3,($t4)
364#    and $t3,0x7f # mask off sign bit (in case first word)
365##...lui $at,0
369##...ori $at,$at,0x7f
373##...and $t3,$t3,$at
376#    sb $t3,-8($t0)
380#    addu $t4,1
384#    addu $t0,1
388#    blt $t4,$t2,toString_copyLoop
389##...slt $at,$t4,$t2
393##...bne $at,$zero,360

    # copy the '@' sign
396#    li $t3,'@'
400#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
404#    addu $t2,$t0,$t1 # address of last byte in string to store +8
408#    lw $t3,20($sp) # hash code to print
412:toString_hashCopyLoop:
412#    and $t4,$t3,0xf
416#    srl $t3,4
420#    lb $t4,hexChars($t4)
424#    sb $t4,-8($t2)
428#    subu $t2,$t2,1
432#    bgt $t2,$t0,toString_hashCopyLoop
433##...slt $at,$t0,$t2
437##...bne $at,$zero,412

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
440#    addu $sp,28
444#    lw $ra,($sp)
448#    addu $sp,4
452#    move $t0, $s7 # return string we created
456#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
460:mth_equals_String:
    
    # quick test for obvious false
460#    lw $t0,($sp) # second parameter
464#    beq $t0,$zero,goEsFalse # go return false if null
468#    lw $t1,-12($t0) # vtable pointer
472#    la $t2,CLASS_String # string vtable pointer
476#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
480#    subu $sp,12
484#    sw $ra,8($sp)
488#    sw $s2,4($sp)
492#    sw $t0,($sp)
496#    jal mth_compareTo_String
500#    lw $s2, 4($sp) #restore this pointer and pop parameters
504#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
508#    seq $t0,$t0,$zero
509##...subu $at,$t0,$zero
513##...sltiu $t0,$at,1

    # pop return address and return $t0
516#    lw $ra,($sp)
520#    addu $sp,4

524#    jr $ra # return
    
528:goEsFalse:
    # put 0 in $t0 and return
528#    li $t0, 0
532#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
536:mth_toString_String:
    #we are a string, so return this.
536#    move $t0, $s2
540#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
544:mth_readLine_Lib:
    
544#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
548#    sw $ra, 4($sp) # save $ra
552#    move $t1,$sp # save "original" sp

556:  doRead:

    # read the character
556#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
560#    subu $t2,$v0,13
564#    bne $t2,$zero,notReturnRL
568#    jal readLogicalChar
572#    subu $t2,$v0,10 # check for newline
576#    beq $t2,$zero,foundNewLine
580#    sw $v0,lastCharRead # push back character into queue
584#    j foundNewLine # go process the line

588:  notReturnRL:

    # at this point, $v0 has our character

588#    subu $t0,$v0,10
592#    beq $t0,$zero,foundNewLine
596#    blt $v0,$zero,foundEof
597##...slt $at,$v0,$zero
601##...bne $at,$zero,616

    # we have a character, so push it onto stack
604#    subu $sp,$sp,4
608#    sw $v0,($sp)

    # loop back up to get next character
612#    j doRead

616:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
616#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
620#    li $s7, 0 # return-value: null
624#    j rlReturn # return

628:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
628#    subu $t0,$t1,$sp # number of chars we read (times 4)
632#    srl $s6,$t0,2 # number of words on stack with chars
636#    subu $sp,$sp,4 # push char-count ...
640#    sw $s6,($sp) # ... onto stack
644#    addu $t2,$t0,5 # GC tag, incl. for count-word
648#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
652#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
656#    srl $s6,$s6,2  # data words in object
660#    move $s7,$zero # object words in object
664#    jal newObject  # allocate space
    
    # store header words
668#    la $t0,CLASS_String
672#    sw $t0,-12($s7)# store class tag (String) into object
676#    lw $t2,4($sp) # char-count
680#    sll $t1,$t2,2 # 4 times number of chars
684#    subu $t2,$zero,$t2 # negative of char-count
