877##...beq $at,$zero,3160
880#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

884:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

884#    jal readLogicalChar # read next character
888#    subu $t1,$v0,'0' # convert digit to 0-9 value
892#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
893##...sltu $at,$t1,$t2
897##...beq $at,$zero,916

900#    mul $t3,$t3,$t2 # multiply old value by 10
901##...mult $t3,$t2
905##...mflo $t3
908#    addu $t3,$t3,$t1 # add in value of new digit
912#    j digitLoop

916:  doneDigitLoop:

    # "push back" unused character into queue
916#    sw $v0,lastCharRead
