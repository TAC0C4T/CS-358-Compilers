
788:  riSkipWhiteLoop:
    # read a character
788#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
792#    subu $t0,$v0,32
796#    bgt $t0,$zero,nonWhite
797##...slt $at,$zero,$t0
801##...bne $at,$zero,844
804#    beq $t0,$zero,riSkipWhiteLoop # start over if space
808#    subu $t0,$v0,10
812#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
816#    subu $t0,$v0,9
820#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
824#    subu $t0,$v0,13
828#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
832#    subu $t0,$v0,12
836#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
840#    j badIntegerFormat # illegal integer char: abort program

844:  nonWhite:
844#    subu $t0,$v0,'-'
848#    li $t4,1 # final multiplier
852#    bne $t0,$zero,helpReadInt # go read
856#    li $t4,-1 # -1 in final multiplier
