########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3012:instanceOf:
    # get object, go return false if null
3012#    lw $t2,($sp)
3016#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3020#    lw $t2,-12($t2) # vtable address
3024#    sge $t0,$t2,$t0 # are we >= the lower limit?
3025##...slt $t0,$t2,$t0
3029##...xori $t0,$t0,0x1
3032#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3036#    and $t2,$t0,$t1
3040#    sw $t2,($sp)
3044:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3044#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3048:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3048#    li $v0,4 # syscall-code for print-string
3052#    syscall
3056:exit:
    # print termination message
3056#    li $v0,4 # syscall-code for print-string
3060#    la $a0,exitString
3064#    syscall

    # print number of garbage collections
3068#    li $v0,4 # syscall-code for print-string
3072#    la $a0,gcCountMsg
3076#    syscall # print "Number of ..."
3080#    lw $a0,gcCount # number of GC's
3084#    li $v0,1 # code for print-int
3088#    syscall
3092#    li $v0,4 # syscall-code for print-string
3096#    la $a0,newlineString
3100#    syscall # print newline

    # terminate execution
3104#    li $v0,10 #syscall-code for "exit"
3108#    syscall

3112:outOfHeapMemory:
3112#    la $a0,heapMemoryMsg
3116#    j exitError
3120:divByZeroError:
3120#    la $a0,divByZeroMsg
3124#    j exitError
3128:strIndexOutOfBounds:
3128#    la $a0,strIndexOutOfBoundsMsg
3132#    j exitError
3136:arrayIndexOutOfBounds:
3136#    la $a0,arrayIndexOutOfBoundsMsg
3140#    j exitError
3144:arraySizeOutOfBounds:
3144#    la $a0,arraySizeOutOfBoundsMsg
3148#    j exitError
3152:nullPtrException:
3152#    la $a0,nullPtrExceptionMsg
3156#    j exitError
3160:badIntegerFormat:
3160#    la $a0,badIntegerFormatMsg
3164#    j exitError
3168:castException:
3168#    la $a0,castExceptionMsg
3172#    j exitError
############## data section ################
    .data
3364:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3380:cur_seg:
    .word 0

3384:lastCharRead:
    .word -2 # -2 => no buffered character
3388:prevHashConstant:
    .word 0x2785173c
3392:gcCount:
    .word 0

3396:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3423:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3446:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3481:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3515:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3548:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3579:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3627:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3648:gcMsg: 
      .asciiz "\nGC!\n"
3654:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3686:nullStr:
    .asciiz "null"
3691:trueString:
    .asciiz "true"
3696:falseString:
    .asciiz "false"
3702:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
3730:newlineString:
    .asciiz "\n"
    
    .align 2
3732:stack_bottom:
    .word 0

