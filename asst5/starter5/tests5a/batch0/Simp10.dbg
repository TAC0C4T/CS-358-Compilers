0:main:
0#  jal vm_init
4#  li $v0, 10
8#  syscall
12:mth_main_Main:
12#  li $t0, 27
16#  subu $sp, $sp, 8
20#  sw $s5, 4($sp)
24#  sw $t0, 0($sp)
28#  li $t0, 263
32#  subu $sp, $sp, 8
36#  sw $s5, 4($sp)
40#  sw $t0, 0($sp)
44#  lw $t2, ($sp)
48#  addu $sp, $sp, 4
52#  lw $t1, ($sp)
56#  addu $sp, $sp, 4
60#  subu $t0, $t1, $t2
64#  subu $sp, $sp, 4
68#  sw $t0, ($sp)
72#  subu $sp, $sp, 4
76#  sw $s2, ($sp)
80#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
84:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
84#    lw $t0,-8($s2) # get word with hash bits from this
88#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
92#    addu $t0,$t1

96#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
100:mth_equals_Object:
100#    move $t0,$s2 # first pointer (this)
104#    lw $t1,($sp) # second pointer
108#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
109##...subu $at,$t0,$t1
113##...sltiu $t0,$at,1

116#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
120:mth_hashCode_String:
120#    move $t0,$s2 # put this pointer in t0

124#    li $t2,0 # current hash value
128#    lw $t1,-4($t0) # negative of number of characters in string
132#    beq $t1,$zero,done_hashCode_String # if zero length => done
136#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
140#    and $t0,0xfffffffc # adjust for padding
141##...lui $at,65535
145##...ori $at,$at,0xfffc
149##...and $t0,$t0,$at
152#    subu $t1,$t0,$t1 # address at end of string +12
156:loop_hashCode_String:    
156#    sll $t4,$t2,5 # multiply by 32
160#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
164#    lbu $t3,-12($t0) # current character
168#    addu $t2,$t3 # add in current character
172#    addu $t0,1 # go to next character's address
176#    bne $t0,$t1,loop_hashCode_String # loop back if more
180:done_hashCode_String:    

    # push int on stack
180#    move $t0, $t2 # put $t2 in return slot
184#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
188:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
188#    subu $sp,4
192#    sw $ra,($sp)
    
    # get hash value
196#    lw $t2,-12($s2) # vtable address
200#    lw $t0,($t2) # method address
204#    jalr $t0
208#    subu $sp,8 # push result (int in $t0) on stack
212#    sw $s5,4($sp)
216#    sw $t0,($sp)

    # compute print-size of hash value
220#    li $t0, 1
224#    lw $t1, ($sp)
228#    srl $t1,$t1,4
232#    beq $t1,$zero,toString_skip_loop
236:toString_loop_top:
236#    addu $t0,1
240#    srl $t1,$t1,4
244#    bne $t1,$zero,toString_loop_top
248:toString_skip_loop:
248#    subu $sp,8
252#    sw $s5,4($sp)
256#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
260#    lw $t2,-12($s2) # vtable address
264#    move $t0,$t2
268:toString_checkTagBit:
268#    subu $t0,1
272#    lb $t1,($t0)
276#    and $t1,0x80
277##...lui $at,0
281##...ori $at,$at,0x80
285##...and $t1,$t1,$at
288#    beq $t1,$zero,toString_checkTagBit
292#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
296#    subu $sp,8
300#    sw $t1,($sp)
304#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
308#    move $s7,$zero # -4 offset header word
312#    lw $t4,8($sp) # bytes for hash value
316#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
320#    addu $t4,8
324#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
328#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

332#    li $t0,CLASS_String # store string vtable address into ...
336#    sw $t0,-12($s7) # ... -12 offset in object header
340#    lw $t2,-12($s2) # our object's vtable address
344#    lw $t5,4($sp) # number characters in prefix
348#    lw $t1,12($sp) # number of characters in hashcode
352#    addu $t3,$t1,$t5 # number of characters in string ...
356#    addu $t3,1 # ... including the '@' character
360#    subu $t0,$zero,$t3 # store negated length into ...
364#    sw $t0,-4($s7) # ... -4 offset header word
368#    lw $t0,-8($s7) # get -8 offset header-word
372#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
373##...slt $at,$t0,$zero
377##...beq $at,$zero,396
380#    and $t0,0xff # mask off object's hash value ...
381##...lui $at,0
385##...ori $at,$at,0xff
389##...and $t0,$t0,$at
392#    sw $t0,-8($s7) # ... and store back into -8 header-word
396:skipMask_toString:
396#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
400#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
404#    subu $t4,$t2,$t5
408:toString_copyLoop:    
408#    lb $t3,($t4)
412#    and $t3,0x7f # mask off sign bit (in case first word)
413##...lui $at,0
417##...ori $at,$at,0x7f
421##...and $t3,$t3,$at
424#    sb $t3,-8($t0)
428#    addu $t4,1
432#    addu $t0,1
436#    blt $t4,$t2,toString_copyLoop
437##...slt $at,$t4,$t2
441##...bne $at,$zero,408

    # copy the '@' sign
444#    li $t3,'@'
448#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
452#    addu $t2,$t0,$t1 # address of last byte in string to store +8
456#    lw $t3,20($sp) # hash code to print
460:toString_hashCopyLoop:
460#    and $t4,$t3,0xf
464#    srl $t3,4
468#    lb $t4,hexChars($t4)
472#    sb $t4,-8($t2)
476#    subu $t2,$t2,1
480#    bgt $t2,$t0,toString_hashCopyLoop
481##...slt $at,$t0,$t2
485##...bne $at,$zero,460

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
488#    addu $sp,28
492#    lw $ra,($sp)
496#    addu $sp,4
500#    move $t0, $s7 # return string we created
504#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
508:mth_equals_String:
    
    # quick test for obvious false
508#    lw $t0,($sp) # second parameter
512#    beq $t0,$zero,goEsFalse # go return false if null
516#    lw $t1,-12($t0) # vtable pointer
520#    la $t2,CLASS_String # string vtable pointer
524#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
528#    subu $sp,12
532#    sw $ra,8($sp)
536#    sw $s2,4($sp)
540#    sw $t0,($sp)
544#    jal mth_compareTo_String
548#    lw $s2, 4($sp) #restore this pointer and pop parameters
552#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
556#    seq $t0,$t0,$zero
557##...subu $at,$t0,$zero
561##...sltiu $t0,$at,1

    # pop return address and return $t0
564#    lw $ra,($sp)
568#    addu $sp,4

572#    jr $ra # return
    
576:goEsFalse:
    # put 0 in $t0 and return
576#    li $t0, 0
580#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
584:mth_toString_String:
    #we are a string, so return this.
584#    move $t0, $s2
588#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
592:mth_readLine_Lib:
    
592#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
596#    sw $ra, 4($sp) # save $ra
600#    move $t1,$sp # save "original" sp

604:  doRead:

    # read the character
604#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
608#    subu $t2,$v0,13
612#    bne $t2,$zero,notReturnRL
616#    jal readLogicalChar
620#    subu $t2,$v0,10 # check for newline
624#    beq $t2,$zero,foundNewLine
628#    sw $v0,lastCharRead # push back character into queue
632#    j foundNewLine # go process the line

636:  notReturnRL:

    # at this point, $v0 has our character

636#    subu $t0,$v0,10
640#    beq $t0,$zero,foundNewLine
644#    blt $v0,$zero,foundEof
645##...slt $at,$v0,$zero
649##...bne $at,$zero,664

    # we have a character, so push it onto stack
652#    subu $sp,$sp,4
656#    sw $v0,($sp)

    # loop back up to get next character
660#    j doRead

664:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
664#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
668#    li $s7, 0 # return-value: null
672#    j rlReturn # return

676:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
676#    subu $t0,$t1,$sp # number of chars we read (times 4)
680#    srl $s6,$t0,2 # number of words on stack with chars
684#    subu $sp,$sp,4 # push char-count ...
688#    sw $s6,($sp) # ... onto stack
692#    addu $t2,$t0,5 # GC tag, incl. for count-word
