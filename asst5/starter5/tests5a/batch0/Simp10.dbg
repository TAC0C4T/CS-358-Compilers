########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
2936:vm_init:

    # mark bottom of stack
2936#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
2940#    move $s2,$zero

    #set up the "five" register
2944#    li $s5,5

2948#    la $s3,seg0_start
2952#    la $s4,seg0_end
2953##...lui $s4,16
2957##...addiu $s4,$s4,3776
    
    # return
2960#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
2964:divide:
    # get parameters; abort if divisor zero
2964#    lw $t0,($sp)
2968#    lw $t1,8($sp)
2972#    beq $t0,$zero,divByZeroError
    
    # perform division
2976#    div $t1,$t0
2980#    mflo $t0

    # store result, adjust stack and return
2984#    addu $sp,$sp,8 # adjust stack
2988#    sw $t0,($sp) # store result
2992#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
2996:remainder:
    # get parameters; abort if divisor zero
2996#    lw $t0,($sp)
3000#    lw $t1,8($sp)
3004#    beq $t0,$zero,divByZeroError
    
    # perform division
3008#    div $t1,$t0
3012#    mfhi $t0

    # store result, adjust stack and return
3016#    addu $sp,$sp,8 # adjust stack
3020#    sw $t0,($sp) # store result
3024#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3028:checkCast:
    # get object, allow immediately if null
3028#    lw $t2,($sp)
3032#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3036#    lw $t2,-12($t2) # vtable address
3040#    bge $t2,$t1,castException
3041##...slt $at,$t2,$t1
3045##...beq $at,$zero,3216
3048#    blt $t2,$t0,castException
3049##...slt $at,$t2,$t0
3053##...bne $at,$zero,3216
    
    # return, leaving object unchanged on stack
3056:  checkCastReturn:    
3056#    jr $ra    

