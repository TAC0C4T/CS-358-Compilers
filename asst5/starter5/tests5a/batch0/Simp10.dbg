856#    subu $t0,$v0,10
860#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
864#    subu $t0,$v0,9
868#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
872#    subu $t0,$v0,13
876#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
880#    subu $t0,$v0,12
884#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
888#    j badIntegerFormat # illegal integer char: abort program

