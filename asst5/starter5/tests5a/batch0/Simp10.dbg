2261##...lui $at,32768
2265##...or $t1,$at,$t1
2268#    and $t1,0xffffff00 # clear low bit
2269##...lui $at,65535
2273##...ori $at,$at,0xff00
2277##...and $t1,$t1,$at
2280#    or $s6,$t1
2284:firstHeaderLarge:
2284#    sw $s6,-8($t0) # store header-1 value
2288#    lw $zero,-8($t0)

    # store second header-value
2292#    sw $s7,-4($t0)   # second header-word
2296#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
2300#    move $s7,$t0
2304#    subu $sp,$sp,4
2308#    sw $t0,($sp)
