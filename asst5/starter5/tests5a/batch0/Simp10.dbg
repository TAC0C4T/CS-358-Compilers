########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3060:instanceOf:
    # get object, go return false if null
3060#    lw $t2,($sp)
3064#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3068#    lw $t2,-12($t2) # vtable address
3072#    sge $t0,$t2,$t0 # are we >= the lower limit?
3073##...slt $t0,$t2,$t0
3077##...xori $t0,$t0,0x1
3080#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3084#    and $t2,$t0,$t1
3088#    sw $t2,($sp)
3092:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3092#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3096:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3096#    li $v0,4 # syscall-code for print-string
3100#    syscall
3104:exit:
    # print termination message
3104#    li $v0,4 # syscall-code for print-string
3108#    la $a0,exitString
3112#    syscall

    # print number of garbage collections
3116#    li $v0,4 # syscall-code for print-string
3120#    la $a0,gcCountMsg
3124#    syscall # print "Number of ..."
3128#    lw $a0,gcCount # number of GC's
3132#    li $v0,1 # code for print-int
3136#    syscall
3140#    li $v0,4 # syscall-code for print-string
3144#    la $a0,newlineString
3148#    syscall # print newline

    # terminate execution
3152#    li $v0,10 #syscall-code for "exit"
3156#    syscall

3160:outOfHeapMemory:
3160#    la $a0,heapMemoryMsg
3164#    j exitError
3168:divByZeroError:
3168#    la $a0,divByZeroMsg
3172#    j exitError
3176:strIndexOutOfBounds:
3176#    la $a0,strIndexOutOfBoundsMsg
3180#    j exitError
3184:arrayIndexOutOfBounds:
3184#    la $a0,arrayIndexOutOfBoundsMsg
3188#    j exitError
3192:arraySizeOutOfBounds:
3192#    la $a0,arraySizeOutOfBoundsMsg
3196#    j exitError
3200:nullPtrException:
3200#    la $a0,nullPtrExceptionMsg
3204#    j exitError
3208:badIntegerFormat:
3208#    la $a0,badIntegerFormatMsg
3212#    j exitError
3216:castException:
3216#    la $a0,castExceptionMsg
3220#    j exitError
############## data section ################
    .data
3404:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3420:cur_seg:
    .word 0

3424:lastCharRead:
    .word -2 # -2 => no buffered character
3428:prevHashConstant:
    .word 0x2785173c
3432:gcCount:
    .word 0

3436:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3463:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3486:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3521:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3555:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3588:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3619:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3667:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3688:gcMsg: 
      .asciiz "\nGC!\n"
3694:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3726:nullStr:
    .asciiz "null"
3731:trueString:
    .asciiz "true"
3736:falseString:
    .asciiz "false"
3742:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
3770:newlineString:
    .asciiz "\n"
    
    .align 2
3772:stack_bottom:
    .word 0
