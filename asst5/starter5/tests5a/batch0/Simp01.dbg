796#    sw $ra,($sp)

800:  riSkipWhiteLoop:
    # read a character
800#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
804#    subu $t0,$v0,32
808#    bgt $t0,$zero,nonWhite
809##...slt $at,$zero,$t0
813##...bne $at,$zero,856
816#    beq $t0,$zero,riSkipWhiteLoop # start over if space
820#    subu $t0,$v0,10
824#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
828#    subu $t0,$v0,9
832#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
836#    subu $t0,$v0,13
840#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
844#    subu $t0,$v0,12
848#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
852#    j badIntegerFormat # illegal integer char: abort program

856:  nonWhite:
856#    subu $t0,$v0,'-'
860#    li $t4,1 # final multiplier
864#    bne $t0,$zero,helpReadInt # go read
868#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
