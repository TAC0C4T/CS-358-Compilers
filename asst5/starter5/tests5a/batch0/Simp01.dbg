2040#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
2044#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
2048#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
2052:  cmpHitLimitzz:
2052#    move $t0, $t5 # store return value
