3060:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3060#    li $v0,4 # syscall-code for print-string
3064#    syscall
3068:exit:
    # print termination message
3068#    li $v0,4 # syscall-code for print-string
3072#    la $a0,exitString
3076#    syscall

    # print number of garbage collections
3080#    li $v0,4 # syscall-code for print-string
3084#    la $a0,gcCountMsg
3088#    syscall # print "Number of ..."
3092#    lw $a0,gcCount # number of GC's
3096#    li $v0,1 # code for print-int
3100#    syscall
3104#    li $v0,4 # syscall-code for print-string
3108#    la $a0,newlineString
3112#    syscall # print newline

    # terminate execution
3116#    li $v0,10 #syscall-code for "exit"
3120#    syscall

3124:outOfHeapMemory:
3124#    la $a0,heapMemoryMsg
3128#    j exitError
3132:divByZeroError:
3132#    la $a0,divByZeroMsg
3136#    j exitError
3140:strIndexOutOfBounds:
3140#    la $a0,strIndexOutOfBoundsMsg
3144#    j exitError
3148:arrayIndexOutOfBounds:
3148#    la $a0,arrayIndexOutOfBoundsMsg
3152#    j exitError
3156:arraySizeOutOfBounds:
3156#    la $a0,arraySizeOutOfBoundsMsg
3160#    j exitError
3164:nullPtrException:
3164#    la $a0,nullPtrExceptionMsg
3168#    j exitError
3172:badIntegerFormat:
3172#    la $a0,badIntegerFormatMsg
3176#    j exitError
3180:castException:
3180#    la $a0,castExceptionMsg
3184#    j exitError
############## data section ################
    .data
3336:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3352:cur_seg:
    .word 0

3356:lastCharRead:
    .word -2 # -2 => no buffered character
3360:prevHashConstant:
    .word 0x2785173c
3364:gcCount:
    .word 0

3368:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3395:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3418:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3453:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3487:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3520:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3551:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3599:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3620:gcMsg: 
      .asciiz "\nGC!\n"
3626:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3658:nullStr:
    .asciiz "null"
3663:trueString:
    .asciiz "true"
3668:falseString:
    .asciiz "false"
3674:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
3702:newlineString:
    .asciiz "\n"
    
    .align 2
3704:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3708:seg0_start:
    .space 0x100000
1052284:seg0_end:
1052284:seg1_start:
    .space 0x100000
2100860:seg1_end:
