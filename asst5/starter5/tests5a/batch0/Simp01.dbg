885##...sltu $at,$t1,$t2
889##...beq $at,$zero,3172
892#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

896:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

896#    jal readLogicalChar # read next character
900#    subu $t1,$v0,'0' # convert digit to 0-9 value
904#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
905##...sltu $at,$t1,$t2
909##...beq $at,$zero,928

912#    mul $t3,$t3,$t2 # multiply old value by 10
913##...mult $t3,$t2
917##...mflo $t3
920#    addu $t3,$t3,$t1 # add in value of new digit
924#    j digitLoop

928:  doneDigitLoop:

    # "push back" unused character into queue
928#    sw $v0,lastCharRead
