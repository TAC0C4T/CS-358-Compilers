0:main:
0#  jal vm_init
4#  li $s6, 1
8#  li $s7, 0
12#  jal newObject
16#  la $t0, CLASS_Main
20#  sw $t0, -12($s7)
24#  addu $sp,$sp,4
28#  move $s2, $s7
32#  jal mth_main_Main
36#  li $v0, 10
40#  syscall
44:mth_main_Main:
44#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
48:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
48#    lw $t0,-8($s2) # get word with hash bits from this
52#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
56#    addu $t0,$t1

60#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
64:mth_equals_Object:
64#    move $t0,$s2 # first pointer (this)
68#    lw $t1,($sp) # second pointer
72#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
73##...subu $at,$t0,$t1
77##...sltiu $t0,$at,1

80#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
84:mth_hashCode_String:
84#    move $t0,$s2 # put this pointer in t0

88#    li $t2,0 # current hash value
92#    lw $t1,-4($t0) # negative of number of characters in string
96#    beq $t1,$zero,done_hashCode_String # if zero length => done
100#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
104#    and $t0,0xfffffffc # adjust for padding
105##...lui $at,65535
109##...ori $at,$at,0xfffc
113##...and $t0,$t0,$at
116#    subu $t1,$t0,$t1 # address at end of string +12
120:loop_hashCode_String:    
120#    sll $t4,$t2,5 # multiply by 32
124#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
128#    lbu $t3,-12($t0) # current character
132#    addu $t2,$t3 # add in current character
136#    addu $t0,1 # go to next character's address
140#    bne $t0,$t1,loop_hashCode_String # loop back if more
144:done_hashCode_String:    

    # push int on stack
144#    move $t0, $t2 # put $t2 in return slot
148#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
152:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
152#    subu $sp,4
156#    sw $ra,($sp)
    
    # get hash value
160#    lw $t2,-12($s2) # vtable address
164#    lw $t0,($t2) # method address
168#    jalr $t0
172#    subu $sp,8 # push result (int in $t0) on stack
176#    sw $s5,4($sp)
180#    sw $t0,($sp)

    # compute print-size of hash value
184#    li $t0, 1
188#    lw $t1, ($sp)
192#    srl $t1,$t1,4
196#    beq $t1,$zero,toString_skip_loop
200:toString_loop_top:
200#    addu $t0,1
204#    srl $t1,$t1,4
208#    bne $t1,$zero,toString_loop_top
212:toString_skip_loop:
212#    subu $sp,8
216#    sw $s5,4($sp)
220#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
224#    lw $t2,-12($s2) # vtable address
228#    move $t0,$t2
232:toString_checkTagBit:
232#    subu $t0,1
236#    lb $t1,($t0)
240#    and $t1,0x80
241##...lui $at,0
245##...ori $at,$at,0x80
249##...and $t1,$t1,$at
252#    beq $t1,$zero,toString_checkTagBit
256#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
260#    subu $sp,8
264#    sw $t1,($sp)
268#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
272#    move $s7,$zero # -4 offset header word
276#    lw $t4,8($sp) # bytes for hash value
280#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
284#    addu $t4,8
288#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
292#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

296#    li $t0,CLASS_String # store string vtable address into ...
300#    sw $t0,-12($s7) # ... -12 offset in object header
304#    lw $t2,-12($s2) # our object's vtable address
308#    lw $t5,4($sp) # number characters in prefix
312#    lw $t1,12($sp) # number of characters in hashcode
316#    addu $t3,$t1,$t5 # number of characters in string ...
320#    addu $t3,1 # ... including the '@' character
324#    subu $t0,$zero,$t3 # store negated length into ...
328#    sw $t0,-4($s7) # ... -4 offset header word
332#    lw $t0,-8($s7) # get -8 offset header-word
336#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
337##...slt $at,$t0,$zero
341##...beq $at,$zero,360
344#    and $t0,0xff # mask off object's hash value ...
345##...lui $at,0
349##...ori $at,$at,0xff
353##...and $t0,$t0,$at
356#    sw $t0,-8($s7) # ... and store back into -8 header-word
360:skipMask_toString:
360#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
364#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
368#    subu $t4,$t2,$t5
372:toString_copyLoop:    
372#    lb $t3,($t4)
376#    and $t3,0x7f # mask off sign bit (in case first word)
377##...lui $at,0
381##...ori $at,$at,0x7f
385##...and $t3,$t3,$at
388#    sb $t3,-8($t0)
392#    addu $t4,1
396#    addu $t0,1
400#    blt $t4,$t2,toString_copyLoop
401##...slt $at,$t4,$t2
405##...bne $at,$zero,372

    # copy the '@' sign
408#    li $t3,'@'
412#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
416#    addu $t2,$t0,$t1 # address of last byte in string to store +8
420#    lw $t3,20($sp) # hash code to print
424:toString_hashCopyLoop:
424#    and $t4,$t3,0xf
428#    srl $t3,4
432#    lb $t4,hexChars($t4)
436#    sb $t4,-8($t2)
440#    subu $t2,$t2,1
444#    bgt $t2,$t0,toString_hashCopyLoop
445##...slt $at,$t0,$t2
449##...bne $at,$zero,424

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
452#    addu $sp,28
456#    lw $ra,($sp)
460#    addu $sp,4
464#    move $t0, $s7 # return string we created
468#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
472:mth_equals_String:
    
    # quick test for obvious false
472#    lw $t0,($sp) # second parameter
476#    beq $t0,$zero,goEsFalse # go return false if null
480#    lw $t1,-12($t0) # vtable pointer
484#    la $t2,CLASS_String # string vtable pointer
488#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
492#    subu $sp,12
496#    sw $ra,8($sp)
500#    sw $s2,4($sp)
504#    sw $t0,($sp)
508#    jal mth_compareTo_String
512#    lw $s2, 4($sp) #restore this pointer and pop parameters
516#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
520#    seq $t0,$t0,$zero
521##...subu $at,$t0,$zero
525##...sltiu $t0,$at,1

    # pop return address and return $t0
528#    lw $ra,($sp)
532#    addu $sp,4

536#    jr $ra # return
    
540:goEsFalse:
    # put 0 in $t0 and return
540#    li $t0, 0
544#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
548:mth_toString_String:
    #we are a string, so return this.
548#    move $t0, $s2
552#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
556:mth_readLine_Lib:
    
556#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
560#    sw $ra, 4($sp) # save $ra
564#    move $t1,$sp # save "original" sp

568:  doRead:

    # read the character
568#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
572#    subu $t2,$v0,13
576#    bne $t2,$zero,notReturnRL
580#    jal readLogicalChar
584#    subu $t2,$v0,10 # check for newline
588#    beq $t2,$zero,foundNewLine
592#    sw $v0,lastCharRead # push back character into queue
596#    j foundNewLine # go process the line

600:  notReturnRL:

    # at this point, $v0 has our character

600#    subu $t0,$v0,10
604#    beq $t0,$zero,foundNewLine
608#    blt $v0,$zero,foundEof
609##...slt $at,$v0,$zero
613##...bne $at,$zero,628

    # we have a character, so push it onto stack
616#    subu $sp,$sp,4
620#    sw $v0,($sp)

    # loop back up to get next character
624#    j doRead

628:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
628#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
632#    li $s7, 0 # return-value: null
636#    j rlReturn # return

640:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
640#    subu $t0,$t1,$sp # number of chars we read (times 4)
644#    srl $s6,$t0,2 # number of words on stack with chars
648#    subu $sp,$sp,4 # push char-count ...
652#    sw $s6,($sp) # ... onto stack
656#    addu $t2,$t0,5 # GC tag, incl. for count-word
660#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
664#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
668#    srl $s6,$s6,2  # data words in object
672#    move $s7,$zero # object words in object
676#    jal newObject  # allocate space
    
    # store header words
680#    la $t0,CLASS_String
684#    sw $t0,-12($s7)# store class tag (String) into object
688#    lw $t2,4($sp) # char-count
692#    sll $t1,$t2,2 # 4 times number of chars
696#    subu $t2,$zero,$t2 # negative of char-count
700#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
704#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
