##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
16:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
16#    lw $t0,-8($s2) # get word with hash bits from this
20#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
24#    addu $t0,$t1

28#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
32:mth_equals_Object:
32#    move $t0,$s2 # first pointer (this)
36#    lw $t1,($sp) # second pointer
40#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
41##...subu $at,$t0,$t1
45##...sltiu $t0,$at,1

48#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
52:mth_hashCode_String:
52#    move $t0,$s2 # put this pointer in t0

56#    li $t2,0 # current hash value
60#    lw $t1,-4($t0) # negative of number of characters in string
64#    beq $t1,$zero,done_hashCode_String # if zero length => done
68#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
72#    and $t0,0xfffffffc # adjust for padding
73##...lui $at,65535
77##...ori $at,$at,0xfffc
81##...and $t0,$t0,$at
84#    subu $t1,$t0,$t1 # address at end of string +12
88:loop_hashCode_String:    
88#    sll $t4,$t2,5 # multiply by 32
92#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
96#    lbu $t3,-12($t0) # current character
100#    addu $t2,$t3 # add in current character
104#    addu $t0,1 # go to next character's address
108#    bne $t0,$t1,loop_hashCode_String # loop back if more
112:done_hashCode_String:    

    # push int on stack
112#    move $t0, $t2 # put $t2 in return slot
116#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
120:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
120#    subu $sp,4
124#    sw $ra,($sp)
    
    # get hash value
128#    lw $t2,-12($s2) # vtable address
132#    lw $t0,($t2) # method address
136#    jalr $t0
140#    subu $sp,8 # push result (int in $t0) on stack
144#    sw $s5,4($sp)
148#    sw $t0,($sp)

    # compute print-size of hash value
152#    li $t0, 1
156#    lw $t1, ($sp)
160#    srl $t1,$t1,4
164#    beq $t1,$zero,toString_skip_loop
168:toString_loop_top:
168#    addu $t0,1
172#    srl $t1,$t1,4
176#    bne $t1,$zero,toString_loop_top
180:toString_skip_loop:
180#    subu $sp,8
184#    sw $s5,4($sp)
188#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
192#    lw $t2,-12($s2) # vtable address
196#    move $t0,$t2
200:toString_checkTagBit:
200#    subu $t0,1
204#    lb $t1,($t0)
208#    and $t1,0x80
209##...lui $at,0
213##...ori $at,$at,0x80
217##...and $t1,$t1,$at
220#    beq $t1,$zero,toString_checkTagBit
224#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
228#    subu $sp,8
232#    sw $t1,($sp)
236#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
240#    move $s7,$zero # -4 offset header word
244#    lw $t4,8($sp) # bytes for hash value
248#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
252#    addu $t4,8
256#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
260#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

264#    li $t0,CLASS_String # store string vtable address into ...
268#    sw $t0,-12($s7) # ... -12 offset in object header
272#    lw $t2,-12($s2) # our object's vtable address
276#    lw $t5,4($sp) # number characters in prefix
280#    lw $t1,12($sp) # number of characters in hashcode
284#    addu $t3,$t1,$t5 # number of characters in string ...
288#    addu $t3,1 # ... including the '@' character
292#    subu $t0,$zero,$t3 # store negated length into ...
296#    sw $t0,-4($s7) # ... -4 offset header word
300#    lw $t0,-8($s7) # get -8 offset header-word
304#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
305##...slt $at,$t0,$zero
309##...beq $at,$zero,328
312#    and $t0,0xff # mask off object's hash value ...
313##...lui $at,0
317##...ori $at,$at,0xff
321##...and $t0,$t0,$at
324#    sw $t0,-8($s7) # ... and store back into -8 header-word
328:skipMask_toString:
328#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
332#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
336#    subu $t4,$t2,$t5
340:toString_copyLoop:    
340#    lb $t3,($t4)
344#    and $t3,0x7f # mask off sign bit (in case first word)
345##...lui $at,0
349##...ori $at,$at,0x7f
353##...and $t3,$t3,$at
356#    sb $t3,-8($t0)
360#    addu $t4,1
364#    addu $t0,1
368#    blt $t4,$t2,toString_copyLoop
369##...slt $at,$t4,$t2
373##...bne $at,$zero,340

    # copy the '@' sign
376#    li $t3,'@'
380#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
384#    addu $t2,$t0,$t1 # address of last byte in string to store +8
388#    lw $t3,20($sp) # hash code to print
392:toString_hashCopyLoop:
392#    and $t4,$t3,0xf
396#    srl $t3,4
400#    lb $t4,hexChars($t4)
404#    sb $t4,-8($t2)
408#    subu $t2,$t2,1
412#    bgt $t2,$t0,toString_hashCopyLoop
413##...slt $at,$t0,$t2
417##...bne $at,$zero,392

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
420#    addu $sp,28
424#    lw $ra,($sp)
428#    addu $sp,4
432#    move $t0, $s7 # return string we created
436#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
440:mth_equals_String:
    
    # quick test for obvious false
440#    lw $t0,($sp) # second parameter
444#    beq $t0,$zero,goEsFalse # go return false if null
448#    lw $t1,-12($t0) # vtable pointer
452#    la $t2,CLASS_String # string vtable pointer
456#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
460#    subu $sp,12
464#    sw $ra,8($sp)
468#    sw $s2,4($sp)
472#    sw $t0,($sp)
476#    jal mth_compareTo_String
480#    lw $s2, 4($sp) #restore this pointer and pop parameters
484#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
488#    seq $t0,$t0,$zero
489##...subu $at,$t0,$zero
493##...sltiu $t0,$at,1

    # pop return address and return $t0
496#    lw $ra,($sp)
500#    addu $sp,4

504#    jr $ra # return
    
508:goEsFalse:
    # put 0 in $t0 and return
508#    li $t0, 0
512#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
516:mth_toString_String:
    #we are a string, so return this.
516#    move $t0, $s2
520#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
524:mth_readLine_Lib:
    
524#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
528#    sw $ra, 4($sp) # save $ra
532#    move $t1,$sp # save "original" sp

536:  doRead:

    # read the character
536#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
540#    subu $t2,$v0,13
544#    bne $t2,$zero,notReturnRL
548#    jal readLogicalChar
552#    subu $t2,$v0,10 # check for newline
556#    beq $t2,$zero,foundNewLine
560#    sw $v0,lastCharRead # push back character into queue
564#    j foundNewLine # go process the line

568:  notReturnRL:

    # at this point, $v0 has our character

568#    subu $t0,$v0,10
572#    beq $t0,$zero,foundNewLine
576#    blt $v0,$zero,foundEof
577##...slt $at,$v0,$zero
581##...bne $at,$zero,596

    # we have a character, so push it onto stack
584#    subu $sp,$sp,4
588#    sw $v0,($sp)

    # loop back up to get next character
592#    j doRead

596:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
596#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
600#    li $s7, 0 # return-value: null
604#    j rlReturn # return

608:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
608#    subu $t0,$t1,$sp # number of chars we read (times 4)
612#    srl $s6,$t0,2 # number of words on stack with chars
616#    subu $sp,$sp,4 # push char-count ...
620#    sw $s6,($sp) # ... onto stack
624#    addu $t2,$t0,5 # GC tag, incl. for count-word
628#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
632#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
636#    srl $s6,$s6,2  # data words in object
640#    move $s7,$zero # object words in object
644#    jal newObject  # allocate space
    
    # store header words
648#    la $t0,CLASS_String
652#    sw $t0,-12($s7)# store class tag (String) into object
656#    lw $t2,4($sp) # char-count
660#    sll $t1,$t2,2 # 4 times number of chars
664#    subu $t2,$zero,$t2 # negative of char-count
668#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
672#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
676#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
677##...slt $at,$t0,$zero
681##...beq $at,$zero,700
684#    and $t0,0xff # mask off object's hash value ...
685##...lui $at,0
689##...ori $at,$at,0xff
693##...and $t0,$t0,$at
