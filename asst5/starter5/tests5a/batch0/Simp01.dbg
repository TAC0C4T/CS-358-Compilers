3032#    syscall
3036:exit:
    # print termination message
3036#    li $v0,4 # syscall-code for print-string
3040#    la $a0,exitString
3044#    syscall

    # print number of garbage collections
3048#    li $v0,4 # syscall-code for print-string
3052#    la $a0,gcCountMsg
3056#    syscall # print "Number of ..."
3060#    lw $a0,gcCount # number of GC's
3064#    li $v0,1 # code for print-int
3068#    syscall
3072#    li $v0,4 # syscall-code for print-string
3076#    la $a0,newlineString
3080#    syscall # print newline

    # terminate execution
3084#    li $v0,10 #syscall-code for "exit"
3088#    syscall

