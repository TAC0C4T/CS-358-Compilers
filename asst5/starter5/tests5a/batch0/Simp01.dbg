    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
2376#    lw $t2,-8($t1) # possible forwarding tag
2380#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
2384#    lw $t2,-4($t1) # forwarding pointer: object's new address
2388#    sw $t2,4($t0) # update stack value
2392#    j gcTestIterDone1 # do next iteration

2396:  gcNoForward1:
